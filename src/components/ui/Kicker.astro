---
/**
 * Section kicker — an uppercase label with a hand-drawn lime squiggle underline
 * that draws itself in on scroll. The squiggle is absolutely positioned so the
 * kicker box shrinks to the LABEL's width (an inline SVG otherwise imposes its
 * own intrinsic width and overshoots short labels like "Plans").
 */
interface Props {
  text: string;
  align?: "left" | "center";
  class?: string;
}
const { text, align = "left", class: className } = Astro.props;
---

<span class:list={["kicker", align === "center" && "kicker--center", className]} data-reveal>
  <span class="kicker-text">{text}</span>
  <svg
    class="kicker-squiggle"
    viewBox="0 0 130 12"
    fill="none"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      class="kicker-path"
      d="M3 7 Q 16 1, 29 7 T 55 7 T 81 7 T 107 7 T 127 6"
      stroke="var(--color-lime)"
      stroke-width="3.5"
      stroke-linecap="round"
    ></path>
  </svg>
</span>

<style>
  .kicker {
    position: relative;
    display: inline-block;
    padding-bottom: 0.95rem; /* reserve room for the underline below the label */
  }
  .kicker--center {
    text-align: center;
  }
  .kicker-text {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .kicker-squiggle {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 0.6rem;
  }
  .kicker-path {
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
  }
  .kicker.is-visible .kicker-path {
    transition: stroke-dashoffset 0.8s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.1s;
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .kicker-path {
      stroke-dashoffset: 0;
    }
  }
</style>
