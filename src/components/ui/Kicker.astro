---
/**
 * Section kicker — an uppercase label with a hand-drawn lime squiggle underline
 * that draws itself in on scroll. Replaces the old filled lime pill labels.
 * Label colour inherits (currentColor); the squiggle is always lime.
 */
interface Props {
  text: string;
  align?: "left" | "center";
  class?: string;
}
const { text, align = "left", class: className } = Astro.props;
---

<span
  class:list={[
    "kicker inline-flex flex-col gap-2",
    align === "center" && "items-center",
    className,
  ]}
  data-reveal
>
  <span class="text-xs font-semibold uppercase tracking-[0.22em]">{text}</span>
  <svg
    class="kicker-squiggle h-2.5 w-full"
    viewBox="0 0 130 12"
    fill="none"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      class="kicker-path"
      d="M3 7 Q 16 1, 29 7 T 55 7 T 81 7 T 107 7 T 127 6"
      stroke="var(--color-lime)"
      stroke-width="3.5"
      stroke-linecap="round"
    ></path>
  </svg>
</span>

<style>
  .kicker-path {
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
  }
  .kicker.is-visible .kicker-path {
    transition: stroke-dashoffset 0.8s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1)) 0.1s;
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .kicker-path {
      stroke-dashoffset: 0;
    }
  }
</style>
