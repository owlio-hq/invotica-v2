---
/**
 * Invotica logomark — two congruent rounded shapes stacked with a diagonal
 * offset (abstract "forward motion" mark). Top shape is themeable via --logo-i
 * (ink on light, white over dark/blue); the bottom shape is the lime accent.
 */
interface Props {
  withWordmark?: boolean;
  class?: string;
  markClass?: string;
  wordmarkClass?: string;
}
const {
  withWordmark = true,
  class: className,
  markClass,
  wordmarkClass = "text-ink",
} = Astro.props;
---

<a
  href="/"
  class:list={["group inline-flex items-center gap-2.5", className]}
  aria-label="Invotica — home"
>
  <svg
    viewBox="0 0 64 64"
    class:list={["h-8 w-auto", markClass]}
    role="img"
    aria-hidden="true"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <g transform="translate(12 15) skewX(-18)">
      <rect width="32" height="19" rx="8" fill="var(--logo-i, var(--color-ink))" />
    </g>
    <g transform="translate(20 28) skewX(-18)">
      <rect width="32" height="19" rx="8" fill="var(--color-lime)" />
    </g>
  </svg>
  {
    withWordmark && (
      <span
        class:list={[
          "font-display text-[1.5rem] font-semibold tracking-tight",
          wordmarkClass,
        ]}
      >
        invotica
      </span>
    )
  }
</a>
