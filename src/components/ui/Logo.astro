---
/**
 * Invotica logomark — "iv" monogram: a blue "i" (dot + stem, the stem doubles as
 * the left arm of the v) and a green diagonal forming the right arm of the v.
 * The "i" colour is themeable via --logo-i (white over dark backgrounds, blue on
 * light); the green arm is fixed.
 */
interface Props {
  withWordmark?: boolean;
  class?: string;
  markClass?: string;
  wordmarkClass?: string;
}
const {
  withWordmark = true,
  class: className,
  markClass,
  wordmarkClass = "text-ink",
} = Astro.props;
---

<a
  href="/"
  class:list={["group inline-flex items-center gap-2.5", className]}
  aria-label="Invotica — home"
>
  <svg
    viewBox="0 0 64 64"
    class:list={["h-7 w-auto", markClass]}
    role="img"
    aria-hidden="true"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- v right arm (green) -->
    <path d="M44 18 L24.5 46" stroke="#79c40e" stroke-width="9.4" stroke-linecap="round" />
    <!-- i stem / left arm of the v (blue, themeable) -->
    <path d="M21.5 27 V45" stroke="var(--logo-i, var(--color-blue))" stroke-width="9.2" stroke-linecap="round" />
    <!-- i dot -->
    <circle cx="21.5" cy="15" r="5.4" fill="var(--logo-i, var(--color-blue))" />
  </svg>
  {
    withWordmark && (
      <span
        class:list={[
          "font-display text-[1.35rem] font-medium tracking-tight",
          wordmarkClass,
        ]}
      >
        invotica
      </span>
    )
  }
</a>
