---
/**
 * Hand-drawn squiggle arrow — reimplemented from cult-ui's SquiggleArrow as a
 * dependency-free Astro/SVG component. Draws itself in when scrolled into view
 * (give it [data-reveal], which reveal.ts toggles to .is-visible).
 */
interface Props {
  direction?: "right" | "left" | "up" | "down";
  variant?: "wavy" | "bouncy" | "smooth";
  strokeWidth?: number;
  class?: string;
}
const {
  direction = "right",
  variant = "wavy",
  strokeWidth = 2.5,
  class: className,
} = Astro.props;

const paths = {
  wavy: {
    body: "M 15 50 Q 35 35, 55 48 T 95 52 Q 115 48, 135 50 Q 145 52, 155 48",
    head: "M 155 48 Q 147 44, 143 42 M 155 48 Q 148 53, 144 56",
  },
  bouncy: {
    body: "M 15 50 Q 45 32, 65 50 Q 85 68, 105 50 Q 125 32, 145 50 Q 152 54, 158 50",
    head: "M 158 50 Q 149 45, 145 43 M 158 50 Q 150 56, 146 59",
  },
  smooth: {
    body: "M 15 50 Q 60 38, 100 48 Q 135 56, 158 50",
    head: "M 158 50 Q 149 45, 145 43 M 158 50 Q 150 56, 146 59",
  },
};
const rotations = {
  right: "rotate(0)",
  left: "rotate(180 100 50)",
  down: "rotate(90 100 50)",
  up: "rotate(-90 100 50)",
};
const p = paths[variant];
---

<svg
  viewBox="-10 -10 220 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class:list={["squiggle", className]}
  data-reveal
  aria-hidden="true"
>
  <g transform={rotations[direction]}>
    <path class="sq-body" d={p.body} stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" fill="none"></path>
    <path class="sq-head" d={p.head} stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round"></path>
  </g>
</svg>

<style>
  .squiggle .sq-body {
    stroke-dasharray: 360;
    stroke-dashoffset: 360;
  }
  .squiggle .sq-head {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
  }
  .squiggle.is-visible .sq-body {
    transition: stroke-dashoffset 0.9s var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
    stroke-dashoffset: 0;
  }
  .squiggle.is-visible .sq-head {
    transition: stroke-dashoffset 0.5s ease 0.6s;
    stroke-dashoffset: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .squiggle .sq-body,
    .squiggle .sq-head {
      stroke-dashoffset: 0;
    }
  }
</style>
