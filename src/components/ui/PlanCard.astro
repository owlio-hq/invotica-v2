---
import type { Plan, PlanVariant } from "@/data/site";
interface Props {
  plan: Plan;
  /** "teaser" = compact (home); "full" = both billing variants (pricing page). */
  mode?: "teaser" | "full";
}
const { plan, mode = "teaser" } = Astro.props;
const featured = plan.featured;
const cta = plan.id === "pro" ? "Get a quote" : "Build my website";

// Per-plan growth icon (sprout → plant → tree).
const icons: Record<string, string> = {
  starter:
    '<path d="M12 21V11M12 11c0-3-2.2-5-5-5 0 3 2.2 5 5 5Zm0 0c0-3 2.2-5 5-5 0 3-2.2 5-5 5Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  growth:
    '<path d="M12 21V9M12 9C12 5.7 9.3 3 6 3c0 3.3 2.7 6 6 6Zm0 0c0-3.3 2.7-6 6-6 0 3.3-2.7 6-6 6Zm0 3c-2.5 0-4.5-1.6-4.5-3.8C9.5 13.4 12 15 12 15s2.5-1.6 4.5 1.2C16.5 18.4 14.5 21 12 21Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  pro:
    '<path d="M12 22v-6M12 16l-4-3M12 16l4-3M12 16V8M8 13l-3-2.2M16 13l3-2.2M12 8C12 4.7 9.3 2 6 2c0 3.3 2.7 6 6 6Zm0 0c0-3.3 2.7-6 6-6 0 3.3-2.7 6-6 6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
};
const iconSvg = icons[plan.id] ?? icons.starter;
---

<article
  class:list={[
    "group relative flex h-full flex-col rounded-3xl bg-paper-200 p-8 transition-all duration-500 hover:-translate-y-1.5",
    featured ? "ring-2 ring-blue" : "ring-1 ring-paper-300 hover:ring-blue",
  ]}
>
  {
    featured && (
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue px-4 py-1 text-[0.7rem] font-bold uppercase tracking-[0.1em] text-white">
        Most popular
      </span>
    )
  }

  <!-- centred header -->
  <div class="flex flex-col items-center text-center">
    <span class="inline-flex h-9 w-9 text-blue" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" class="h-full w-full" set:html={iconSvg} />
    </span>
    <span class="mt-3 rounded-full bg-white px-3.5 py-1 text-xs font-semibold text-ink-soft ring-1 ring-paper-300">
      {plan.name}
    </span>
  </div>

  {
    mode === "full" ? (
      <>
        {(["onetime", "managed"] as const).map((key) => {
          const v: PlanVariant = key === "onetime" ? plan.oneTime : plan.managed;
          return (
            <div data-when={key} class="flex flex-1 flex-col">
              <div class="mt-6 text-center">
                <div class="flex items-baseline justify-center gap-1.5">
                  <span class="font-display text-[2.4rem] font-bold leading-none text-ink">{v.price}</span>
                  {v.cadence && <span class="text-base font-medium text-ink-soft">{v.cadence}</span>}
                </div>
                <p class="mt-2 text-sm font-medium text-blue">{v.priceNote}</p>
              </div>
              <p class="mt-5 text-center text-sm leading-relaxed text-ink-soft">{v.tagline}</p>
              <ul class="mt-7 flex flex-1 flex-col gap-3">
                {v.features.map((f) => (
                  <li class="flex items-start gap-3 text-sm leading-relaxed">
                    <svg class="mt-0.5 h-4 w-4 shrink-0 text-blue" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span class="text-ink-soft">{f}</span>
                  </li>
                ))}
              </ul>
              <p class="mt-6 text-xs leading-relaxed text-ink-soft/70">{v.footnote}</p>
            </div>
          );
        })}
      </>
    ) : (
      <div class="flex flex-1 flex-col">
        <div class="mt-6 text-center">
          <div class="flex items-baseline justify-center gap-1.5">
            <span class="font-display text-[2.4rem] font-bold leading-none text-ink">{plan.oneTime.price}</span>
          </div>
          <p class="mt-2 text-sm font-medium text-blue">{plan.oneTime.priceNote}</p>
        </div>
        <p class="mt-5 text-center text-sm leading-relaxed text-ink-soft">{plan.oneTime.tagline}</p>
        <div class="mt-6 flex flex-1 flex-wrap content-start justify-center gap-2">
          {plan.examples.map((e) => (
            <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-ink-soft ring-1 ring-paper-300">{e}</span>
          ))}
        </div>
      </div>
    )
  }

  <a
    href="/contact"
    class:list={[
      "mt-8 inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-transform duration-300 hover:-translate-y-0.5",
      featured ? "bg-blue text-white" : "bg-ink text-white",
    ]}
  >
    {cta}
    <span aria-hidden="true">→</span>
  </a>
</article>
