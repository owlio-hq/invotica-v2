---
/**
 * Button / link with the shared outline‚Üífill hover behaviour (.btn in global.css).
 * Renders as <a> when `href` is given, otherwise <button>.
 */
interface Props {
  href?: string;
  variant?: "dark" | "light" | "lime" | "blue";
  size?: "md" | "lg" | "sm";
  type?: "button" | "submit";
  class?: string;
  /** Show the trailing diagonal arrow. */
  arrow?: boolean;
  [key: string]: unknown;
}
const {
  href,
  variant = "dark",
  size = "md",
  type = "button",
  class: className,
  arrow = true,
  ...rest
} = Astro.props;

const cls = [
  "btn",
  `btn-${variant}`,
  size === "lg" && "btn-lg",
  size === "sm" && "btn-sm",
  className,
];
const arrowHtml = `<span class="btn-arrow" aria-hidden="true">‚Üó</span>`;
---

{
  href ? (
    <a href={href} class:list={cls} {...rest}>
      <slot />
      {arrow && <Fragment set:html={arrowHtml} />}
    </a>
  ) : (
    <button type={type} class:list={cls} {...rest}>
      <slot />
      {arrow && <Fragment set:html={arrowHtml} />}
    </button>
  )
}
