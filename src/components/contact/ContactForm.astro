---
import { site, plans } from "@/data/site";
---

<form id="contact-form" class="flex flex-col gap-5" novalidate>
  <!-- Web3Forms config -->
  <input type="hidden" name="access_key" value={site.web3formsKey} />
  <input type="hidden" name="subject" value="New enquiry from invotica.com" />
  <input type="hidden" name="from_name" value="Invotica Website" />
  <!-- honeypot: bots fill this, humans don't -->
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    style="display:none"
    tabindex="-1"
    autocomplete="off"
  />

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="flex flex-col gap-2">
      <span class="text-sm font-medium text-ink">Name</span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        class="field"
        placeholder="Your name"
      />
    </label>
    <label class="flex flex-col gap-2">
      <span class="text-sm font-medium text-ink">Email</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        class="field"
        placeholder="you@business.com"
      />
    </label>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="flex flex-col gap-2">
      <span class="text-sm font-medium text-ink">Business name</span>
      <input type="text" name="business" class="field" placeholder="Your business" />
    </label>
    <label class="flex flex-col gap-2">
      <span class="text-sm font-medium text-ink">Plan of interest</span>
      <select name="plan" class="field">
        <option value="">Not sure yet</option>
        {plans.map((p) => <option value={p.name}>{p.name}</option>)}
      </select>
    </label>
  </div>

  <label class="flex flex-col gap-2">
    <span class="text-sm font-medium text-ink">Tell us about your project</span>
    <textarea
      name="message"
      required
      rows="5"
      class="field resize-y"
      placeholder="What do you do, and what do you need from a website?"></textarea>
  </label>

  <button
    type="submit"
    class="group mt-2 inline-flex items-center justify-center gap-2 rounded-full bg-terracotta px-8 py-4 font-medium text-cream transition-all duration-300 hover:-translate-y-0.5 hover:bg-terracotta-600 disabled:cursor-not-allowed disabled:opacity-60"
  >
    <span data-label>Send message</span>
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </button>

  <p
    data-status
    role="status"
    aria-live="polite"
    class="hidden rounded-2xl px-4 py-3 text-sm"
  >
  </p>
</form>

<style>
  .field {
    width: 100%;
    border-radius: 0.9rem;
    background: var(--color-cream-200);
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    color: var(--color-ink);
    outline: 1px solid var(--color-cream-300);
    transition: outline-color 0.2s ease, background 0.2s ease;
  }
  .field::placeholder {
    color: color-mix(in srgb, var(--color-ink-soft) 55%, transparent);
  }
  .field:focus {
    outline: 2px solid var(--color-forest);
    background: var(--color-cream);
  }
</style>

<script>
  import { logger } from "@/lib/logger";

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  if (form) {
    const statusEl = form.querySelector<HTMLElement>("[data-status]")!;
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const label = form.querySelector<HTMLElement>("[data-label]")!;

    const show = (msg: string, ok: boolean) => {
      statusEl.textContent = msg;
      statusEl.classList.remove("hidden");
      statusEl.style.background = ok ? "rgba(33,66,57,0.08)" : "rgba(173,79,46,0.1)";
      statusEl.style.color = ok ? "var(--color-forest)" : "var(--color-terracotta-600)";
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      // honeypot
      if ((form.elements.namedItem("botcheck") as HTMLInputElement)?.checked) {
        logger.warn("ContactForm", "honeypot tripped — dropping submit");
        return;
      }

      btn.disabled = true;
      label.textContent = "Sending…";
      logger.info("ContactForm", "submitting enquiry");

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          show("Thanks — your message is on its way. We'll reply within hours.", true);
          label.textContent = "Sent ✓";
          logger.info("ContactForm", "enquiry sent");
        } else {
          throw new Error(data.message || `HTTP ${res.status}`);
        }
      } catch (err) {
        show(
          "Something went wrong. Please email us directly and we'll get right back to you.",
          false,
        );
        label.textContent = "Send message";
        btn.disabled = false;
        logger.error("ContactForm", "submit failed", { err: (err as Error).message });
      }
    });
  }
</script>
