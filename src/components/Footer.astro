---
import { site, nav } from "@/data/site";
import { industries } from "@/data/industries";
const year = new Date().getFullYear();
---

<!-- Dark footer that tucks under the page with a big curved top (the .panel
     move). Editorial: brand + address left, link columns right, giant wordmark,
     thin bottom bar. -->
<footer class="panel on-ink relative overflow-hidden">
  <div class="grid-faint pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>

  <div class="container-x relative">
    <!-- top: brand/address + columns -->
    <div class="grid gap-12 pt-16 sm:pt-20 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 64 64" class="h-9 w-auto" fill="none" aria-hidden="true">
            <g transform="translate(12 15) skewX(-18)"><rect width="32" height="19" rx="8" fill="#ffffff"></rect></g>
            <g transform="translate(20 28) skewX(-18)"><rect width="32" height="19" rx="8" fill="var(--color-lime)"></rect></g>
          </svg>
          <span class="font-display text-[1.6rem] font-semibold tracking-tight text-paper">invotica</span>
        </div>
        <p class="mt-5 max-w-sm text-lead font-light leading-relaxed text-paper/70">
          Custom websites for Canadian businesses — designed to be found, built to convert,
          and yours to keep.
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-7 inline-flex items-center gap-2 text-paper underline decoration-blue/40 decoration-1 underline-offset-[6px] transition-colors hover:text-white hover:decoration-blue-bright"
        >
          {site.email}
        </a>
      </div>

      <div class="grid grid-cols-2 gap-8 lg:col-span-7 lg:grid-cols-3">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-soft">Pages</h3>
          <ul class="mt-5 flex flex-col gap-3 text-sm">
            {
              nav.map((item) => (
                <li>
                  <a class="text-paper/70 transition-colors hover:text-white" href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-soft">Contact</h3>
          <ul class="mt-5 flex flex-col gap-3 text-sm">
            <li>
              <a class="text-paper/70 transition-colors hover:text-white" href={`tel:${site.phoneHref}`}>
                {site.phone}
              </a>
            </li>
            <li><span class="text-paper/55">{site.location}</span></li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-soft">
            {site.social.length > 0 ? "Social" : "Start here"}
          </h3>
          <ul class="mt-5 flex flex-col gap-3 text-sm">
            {
              site.social.length > 0 ? (
                site.social.map((s) => (
                  <li>
                    <a class="text-paper/70 transition-colors hover:text-white" href={s.href}>
                      {s.label}
                    </a>
                  </li>
                ))
              ) : (
                <>
                  <li>
                    <a class="text-paper/70 transition-colors hover:text-white" href="/contact">
                      Get a free quote
                    </a>
                  </li>
                  <li>
                    <a class="text-paper/70 transition-colors hover:text-white" href="/pricing">
                      See pricing
                    </a>
                  </li>
                </>
              )
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- industries strip -->
    <div class="mt-14 border-t border-white/10 pt-8">
      <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-blue-soft">
        Websites we build
      </h3>
      <ul class="mt-5 flex flex-wrap gap-x-6 gap-y-3 text-sm">
        {
          industries.map((industry) => (
            <li>
              <a
                class="text-paper/70 transition-colors hover:text-white"
                href={`/website-design-for-${industry.slug}`}
              >
                {industry.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- giant wordmark -->
    <div
      aria-hidden="true"
      class="mt-10 select-none font-display font-medium leading-[0.8] tracking-tight text-paper/[0.06] text-[clamp(3rem,13vw,9rem)]"
    >
      invotica
    </div>

    <!-- bottom bar -->
    <div
      class="flex flex-col gap-2 border-t border-white/10 py-6 text-xs text-paper/45 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Built to convert · Canada-wide</p>
    </div>
  </div>
</footer>
