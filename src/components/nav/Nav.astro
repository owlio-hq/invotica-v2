---
import Logo from "@/components/ui/Logo.astro";
import MenuOverlay from "./MenuOverlay.astro";
---

<!-- Floating header: two self-contained pills, no full-width bar. Each pill
     carries its own surface so it stays legible on any section beneath it. -->
<header class="pointer-events-none fixed inset-x-0 top-0 z-50">
  <div class="container-x flex items-center justify-between py-4 sm:py-5">
    <Logo
      class="pointer-events-auto rounded-2xl bg-paper/85 px-3.5 py-2.5 shadow-[0_10px_30px_-12px_rgba(11,12,16,0.4)] ring-1 ring-ink/10 backdrop-blur-md transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-0.5"
      wordmarkClass="text-ink"
    />

    <button
      type="button"
      data-menu-open
      aria-expanded="false"
      aria-controls="menu-overlay"
      class="pointer-events-auto group flex items-center gap-3 rounded-full bg-ink px-5 py-3 text-sm font-medium text-paper shadow-[0_10px_30px_-10px_rgba(11,12,16,0.5)] ring-1 ring-white/10 transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-0.5"
    >
      <span class="tracking-tight">Menu</span>
      <span class="relative flex h-3 w-4 flex-col justify-between" aria-hidden="true">
        <span class="h-[1.5px] w-full origin-center rounded bg-current transition-transform duration-300 group-hover:translate-y-[0.5px]"></span>
        <span class="h-[1.5px] w-full origin-center rounded bg-current transition-all duration-300 group-hover:w-2/3"></span>
        <span class="h-[1.5px] w-full origin-center rounded bg-current transition-transform duration-300 group-hover:-translate-y-[0.5px]"></span>
      </span>
    </button>
  </div>
</header>

<MenuOverlay />
