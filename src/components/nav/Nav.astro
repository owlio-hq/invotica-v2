---
import Logo from "@/components/ui/Logo.astro";
import MenuOverlay from "./MenuOverlay.astro";

interface Props {
  /** "dark" = light text over a dark/blue hero (home); "light" = ink text. */
  theme?: "light" | "dark";
}
const { theme = "light" } = Astro.props;
---

<!-- Borderless, scroll-aware top bar. Logo + a single Menu trigger (all sizes)
     that opens a full-screen overlay. -->
<header
  data-nav
  data-theme={theme}
  data-scrolled="false"
  class="nav-header fixed inset-x-0 top-0 z-50 transition-[background-color,box-shadow] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  <div class="container-x flex items-center justify-between py-4 sm:py-5">
    <Logo class="nav-logo transition-opacity hover:opacity-80" wordmarkClass="text-current" />

    <button
      type="button"
      data-menu-open
      aria-expanded="false"
      aria-controls="menu-overlay"
      class="nav-link group flex items-center gap-2.5 text-sm font-semibold uppercase tracking-[0.12em]"
    >
      <span>Menu</span>
      <span class="relative flex h-3 w-5 flex-col justify-between" aria-hidden="true">
        <span class="h-[2px] w-full rounded bg-current transition-transform duration-300 group-hover:translate-y-[1px]"></span>
        <span class="h-[2px] w-full rounded bg-current transition-all duration-300 group-hover:w-3/5"></span>
        <span class="h-[2px] w-full rounded bg-current transition-transform duration-300 group-hover:-translate-y-[1px]"></span>
      </span>
    </button>
  </div>
</header>

<MenuOverlay />

<style>
  .nav-header {
    color: var(--color-ink);
  }
  .nav-header[data-theme="dark"][data-scrolled="false"] {
    color: #fff;
  }
  /* Liquid glass: heavy blur + saturation vibrancy, a translucent sheen, a bright
     top "glass edge" highlight and a soft shadow. Materialises once scrolled. */
  .nav-header[data-scrolled="true"] {
    color: var(--color-ink);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #fff 72%, transparent),
      color-mix(in srgb, #fff 54%, transparent)
    );
    backdrop-filter: blur(18px) saturate(185%);
    -webkit-backdrop-filter: blur(18px) saturate(185%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.65),
      inset 0 -1px 0 color-mix(in srgb, var(--color-ink) 6%, transparent),
      0 14px 38px -24px rgba(10, 10, 10, 0.45);
  }
  @media (prefers-reduced-transparency: reduce) {
    .nav-header[data-scrolled="true"] {
      background: color-mix(in srgb, #fff 92%, transparent);
      backdrop-filter: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-nav]");
  if (header) {
    const update = () =>
      header.setAttribute("data-scrolled", String(window.scrollY > 24));
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>
