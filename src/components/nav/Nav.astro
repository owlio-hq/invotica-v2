---
import Logo from "@/components/ui/Logo.astro";
import MenuOverlay from "./MenuOverlay.astro";

interface Props {
  /** "dark" = light text over a dark/blue hero (home); "light" = ink text. */
  theme?: "light" | "dark";
}
const { theme = "light" } = Astro.props;
---

<!-- Borderless, scroll-aware top bar. Logo + a single Menu trigger (all sizes)
     that opens a full-screen overlay. -->
<header
  data-nav
  data-theme={theme}
  data-scrolled="false"
  class="nav-header fixed inset-x-0 top-0 z-50 transition-[background-color,box-shadow] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
>
  <div class="container-x flex items-center justify-between py-4 sm:py-5">
    <Logo class="nav-logo transition-opacity hover:opacity-80" wordmarkClass="text-current" />

    <button
      type="button"
      data-menu-open
      aria-expanded="false"
      aria-controls="menu-overlay"
      class="nav-link group flex items-center gap-2.5 text-[0.95rem] font-semibold uppercase tracking-[0.12em]"
    >
      <span>Menu</span>
      <span class="relative flex h-3.5 w-5 flex-col justify-between" aria-hidden="true">
        <span class="h-[3px] w-full rounded bg-current transition-transform duration-300 group-hover:translate-y-[1px]"></span>
        <span class="h-[3px] w-full rounded bg-current transition-all duration-300 group-hover:w-3/5"></span>
        <span class="h-[3px] w-full rounded bg-current transition-transform duration-300 group-hover:-translate-y-[1px]"></span>
      </span>
    </button>
  </div>
</header>

<MenuOverlay />

<style>
  .nav-header {
    color: var(--color-ink);
    /* logo top shape: ink on the light/frosted state */
    --logo-i: var(--color-ink);
  }
  .nav-header[data-theme="dark"][data-scrolled="false"] {
    color: #fff;
    --logo-i: #fff; /* white top shape over the blue hero */
  }
  .nav-header[data-scrolled="true"] {
    color: var(--color-ink);
    --logo-i: var(--color-ink);
    background: color-mix(in srgb, var(--color-paper) 82%, transparent);
    backdrop-filter: blur(14px);
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--color-ink) 8%, transparent),
      0 18px 40px -34px rgba(10, 10, 10, 0.5);
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-nav]");
  if (header) {
    const update = () =>
      header.setAttribute("data-scrolled", String(window.scrollY > 24));
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>
