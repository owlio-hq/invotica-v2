---
import { nav, site } from "@/data/site";
---

<!-- Full-screen menu overlay (mobile + desktop). Reveals with a clip-path wipe;
     links + footer rise in on a stagger. -->
<div
  id="menu-overlay"
  data-menu
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  aria-hidden="true"
  class="menu fixed inset-0 z-[60] flex flex-col overflow-hidden bg-blue text-white"
>
  <!-- top bar -->
  <div class="container-x flex items-center justify-between py-4 sm:py-5">
    <span class="flex items-center gap-2.5">
      <svg viewBox="0 0 64 64" class="h-7 w-auto" fill="none" aria-hidden="true">
        <g transform="translate(12 15) skewX(-18)"><rect width="32" height="19" rx="8" fill="#ffffff"></rect></g>
        <g transform="translate(20 28) skewX(-18)"><rect width="32" height="19" rx="8" fill="var(--color-lime)"></rect></g>
      </svg>
      <span class="font-display text-[1.35rem] font-semibold tracking-tight text-white">invotica</span>
    </span>
    <button
      type="button"
      data-menu-close
      class="group flex items-center gap-2.5 rounded-full px-4 py-2.5 text-sm font-semibold uppercase tracking-[0.12em] text-white ring-1 ring-white/30 transition-colors duration-300 hover:bg-white hover:text-blue"
    >
      <span>Close</span>
      <span class="relative block h-3.5 w-3.5" aria-hidden="true">
        <span class="absolute left-1/2 top-1/2 h-[2px] w-full -translate-x-1/2 -translate-y-1/2 rotate-45 rounded bg-current"></span>
        <span class="absolute left-1/2 top-1/2 h-[2px] w-full -translate-x-1/2 -translate-y-1/2 -rotate-45 rounded bg-current"></span>
      </span>
    </button>
  </div>

  <!-- big nav links -->
  <nav class="container-x flex flex-1 flex-col justify-center">
    <ul class="flex flex-col gap-1 sm:gap-2">
      {
        nav.map((item, i) => (
          <li class="menu-item overflow-hidden" style={`--i:${i}`}>
            <a
              href={item.href}
              class="group flex items-baseline gap-5 py-2 font-display text-[clamp(2.75rem,9vw,6.5rem)] font-semibold leading-[1.02] tracking-tight text-white transition-colors duration-300 hover:text-lime"
            >
              <span class="font-sans text-base font-medium text-lime tabular-nums">0{i + 1}</span>
              <span class="relative">
                {item.label}
                <span class="absolute -right-9 top-1/2 -translate-y-1/2 translate-x-2 text-3xl text-lime opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                  →
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- footer row -->
  <div
    class="menu-foot container-x flex flex-col gap-4 border-t border-white/15 py-6 text-sm text-white/70 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-col gap-1">
      <span class="text-white/45">Let's talk</span>
      <a href={`mailto:${site.email}`} class="text-white transition-colors hover:text-lime">
        {site.email}
      </a>
    </div>
    <a href="/contact" class="btn btn-lime w-fit">
      Get a free quote <span class="btn-arrow" aria-hidden="true">↗</span>
    </a>
  </div>

  <!-- watermark -->
  <svg
    viewBox="0 0 64 64"
    fill="none"
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-12 -right-6 h-80 w-auto opacity-[0.08]"
  >
    <g transform="translate(12 15) skewX(-18)"><rect width="32" height="19" rx="8" fill="#fff"></rect></g>
    <g transform="translate(20 28) skewX(-18)"><rect width="32" height="19" rx="8" fill="#fff"></rect></g>
  </svg>
</div>

<style>
  .menu {
    clip-path: inset(0 0 100% 0);
    opacity: 0;
    pointer-events: none;
    transition:
      clip-path 0.7s var(--ease-in-out-quint),
      opacity 0.4s ease;
  }
  .menu[data-open="true"] {
    clip-path: inset(0 0 0 0);
    opacity: 1;
    pointer-events: auto;
  }

  .menu-item a,
  .menu-foot {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.6s var(--ease-out-expo),
      transform 0.6s var(--ease-out-expo);
    transition-delay: calc(0.18s + var(--i, 4) * 0.07s);
  }
  .menu[data-open="true"] .menu-item a,
  .menu[data-open="true"] .menu-foot {
    opacity: 1;
    transform: none;
  }
  .menu-foot {
    --i: 4;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu {
      transition: opacity 0.2s ease;
      clip-path: none;
    }
    .menu-item a,
    .menu-foot {
      transition: none;
      transform: none;
      opacity: 1;
    }
  }
</style>
