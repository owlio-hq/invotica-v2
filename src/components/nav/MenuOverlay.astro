---
import { nav, site } from "@/data/site";
---

<div
  id="menu-overlay"
  data-menu
  data-open="false"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  class="menu fixed inset-0 z-[60] flex flex-col bg-forest text-cream"
>
  <!-- top bar inside overlay -->
  <div class="container-x flex items-center justify-between py-4">
    <span class="font-display text-[1.35rem] font-medium tracking-tight text-cream">
      invotica
    </span>
    <button
      type="button"
      data-menu-close
      class="group flex items-center gap-3 rounded-full px-4 py-2.5 text-sm font-medium text-cream ring-1 ring-cream/25 transition-colors duration-300 hover:bg-cream hover:text-forest"
    >
      <span>Close</span>
      <span class="relative block h-3.5 w-3.5" aria-hidden="true">
        <span
          class="absolute left-1/2 top-1/2 h-[1.5px] w-full -translate-x-1/2 -translate-y-1/2 rotate-45 rounded bg-current"
        ></span>
        <span
          class="absolute left-1/2 top-1/2 h-[1.5px] w-full -translate-x-1/2 -translate-y-1/2 -rotate-45 rounded bg-current"
        ></span>
      </span>
    </button>
  </div>

  <!-- big nav links -->
  <nav class="container-x flex flex-1 flex-col justify-center">
    <ul class="flex flex-col gap-1">
      {
        nav.map((item, i) => (
          <li class="menu-item overflow-hidden" style={`--i:${i}`}>
            <a
              href={item.href}
              class="group flex items-baseline gap-5 py-2 font-display text-[clamp(2.75rem,9vw,6rem)] font-medium leading-[1.02] tracking-tight text-cream/90 transition-colors duration-300 hover:text-terracotta"
            >
              <span class="font-sans text-base font-normal text-sage-300 tabular-nums">
                0{i + 1}
              </span>
              <span class="relative">
                {item.label}
                <span class="absolute -right-8 top-1/2 -translate-y-1/2 translate-x-2 text-3xl opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                  →
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- footer row -->
  <div
    class="menu-foot container-x flex flex-col gap-4 border-t border-cream/15 py-6 text-sm text-cream/70 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-col gap-1">
      <span class="text-cream/45">Let's talk</span>
      <a href={`mailto:${site.email}`} class="text-cream hover:text-terracotta">
        {site.email}
      </a>
    </div>
    <a
      href="/contact"
      class="inline-flex w-fit items-center gap-2 rounded-full bg-terracotta px-6 py-3 font-medium text-cream transition-colors duration-300 hover:bg-terracotta-600"
    >
      Start a project <span aria-hidden="true">→</span>
    </a>
  </div>

  <!-- watermark mark -->
  <svg
    viewBox="0 0 60 64"
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-10 -right-6 h-72 w-auto opacity-[0.06]"
  >
    <rect x="32" y="12" width="18" height="46" rx="6" fill="#fff"></rect>
    <rect x="6" y="26" width="18" height="32" rx="6" fill="#fff"></rect>
    <circle cx="15" cy="11" r="9" fill="#fff"></circle>
  </svg>
</div>

<style>
  .menu {
    clip-path: inset(0 0 100% 0);
    opacity: 0;
    pointer-events: none;
    transition:
      clip-path 0.7s var(--ease-in-out-quint),
      opacity 0.4s ease;
  }
  .menu[data-open="true"] {
    clip-path: inset(0 0 0 0);
    opacity: 1;
    pointer-events: auto;
  }

  /* Staggered entrance for nav links + footer. */
  .menu-item a,
  .menu-foot {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.6s var(--ease-out-expo),
      transform 0.6s var(--ease-out-expo);
    transition-delay: calc(0.18s + var(--i, 4) * 0.07s);
  }
  .menu[data-open="true"] .menu-item a,
  .menu[data-open="true"] .menu-foot {
    opacity: 1;
    transform: none;
  }
  .menu-foot {
    --i: 4;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu {
      transition: opacity 0.2s ease;
      clip-path: none;
    }
    .menu-item a,
    .menu-foot {
      transition: none;
      transform: none;
      opacity: 1;
    }
  }
</style>
