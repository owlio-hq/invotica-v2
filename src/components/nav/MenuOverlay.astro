---
import { nav, site } from "@/data/site";
---

<!-- Compact menu card anchored under the top-right trigger. A dim backdrop sits
     behind it so a tap outside (or Escape) closes it. Mobile-first. -->
<div
  data-menu-backdrop
  class="menu-backdrop fixed inset-0 z-[55] bg-ink/30 backdrop-blur-[2px] md:hidden"
  aria-hidden="true"
>
</div>

<div
  id="menu-overlay"
  data-menu
  data-open="false"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  class="menu-panel fixed right-4 top-[4.75rem] z-[60] w-[min(20rem,calc(100vw-2rem))] origin-top-right overflow-hidden rounded-[1.75rem] bg-ink p-3 text-paper shadow-[0_30px_80px_-30px_rgba(11,12,16,0.85)] ring-1 ring-white/10 md:hidden"
>
  <nav aria-label="Mobile">
    <ul class="flex flex-col">
      {
        nav.map((item, i) => (
          <li>
            <a
              href={item.href}
              class="group flex items-center justify-between rounded-2xl px-4 py-3.5 text-lg font-medium tracking-tight transition-colors duration-200 hover:bg-white/[0.06]"
            >
              <span class="flex items-baseline gap-3">
                <span class="text-xs font-normal tabular-nums text-blue-soft">0{i + 1}</span>
                {item.label}
              </span>
              <span
                class="translate-x-1 text-blue-soft opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="mt-2 border-t border-white/10 p-3">
    <a
      href="/contact"
      class="flex items-center justify-center gap-2 rounded-2xl bg-blue px-5 py-3.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-blue-deep"
    >
      Start a project <span aria-hidden="true">→</span>
    </a>
    <a
      href={`mailto:${site.email}`}
      class="mt-3 block text-center text-xs text-paper/55 transition-colors hover:text-paper"
    >
      {site.email}
    </a>
  </div>

  <button type="button" data-menu-close class="sr-only">Close menu</button>
</div>

<style>
  .menu-panel {
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
    pointer-events: none;
    transition:
      opacity 0.25s var(--ease-out-expo),
      transform 0.35s var(--ease-out-expo);
  }
  .menu-panel[data-open="true"] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .menu-backdrop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .menu-backdrop[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-panel,
    .menu-backdrop {
      transition: opacity 0.15s ease;
      transform: none;
    }
  }
</style>
