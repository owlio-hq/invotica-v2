---
import Kicker from "@/components/ui/Kicker.astro";
import { realDifference as rd } from "@/data/site";

const paths = [
  { n: "01", dark: false, ...rd.found },
  { n: "02", dark: true, ...rd.trusted },
];
---

<section class="section-y container-x" id="difference">
  <div class="max-w-2xl" data-reveal>
    <Kicker text="The real difference" />
    <h2 class="mt-6 text-[clamp(2.2rem,1rem+4vw,4rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
      It's not about a website. It's about what a website <span class="marker">does.</span>
    </h2>
  </div>

  <div class="mt-14 grid gap-6 md:grid-cols-2">
    {
      paths.map((c, i) => (
        <article
          data-reveal
          data-reveal-delay={i * 120}
          class:list={[
            "group relative flex flex-col overflow-hidden rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1.5 sm:p-10",
            c.dark ? "bg-blue text-white" : "bg-paper-200 ring-1 ring-paper-300",
          ]}
        >
          <div class="flex items-center justify-between">
            <span
              class:list={[
                "font-display text-6xl font-semibold leading-none tabular-nums",
                c.dark ? "text-white/15" : "text-ink/10",
              ]}
            >
              {c.n}
            </span>
            <span class="inline-flex rounded-full bg-lime px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-lime-deep">
              {c.tiers}
            </span>
          </div>

          <h3 class="mt-8 font-display text-[clamp(1.6rem,3vw,2.3rem)] font-semibold leading-[1.12]">
            It's <span class="marker">{c.tagline}.</span>
          </h3>

          <p
            class:list={[
              "mt-5 max-w-md leading-relaxed",
              c.dark ? "text-white/75" : "text-ink-soft",
            ]}
          >
            {c.body}
          </p>
        </article>
      ))
    }
  </div>

  <p class="mx-auto mt-12 max-w-2xl text-center text-sm leading-relaxed text-ink-soft" data-reveal>
    {rd.note}
  </p>
</section>
