---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { realDifference as rd } from "@/data/site";

const paths = [
  { n: "01", ...rd.found },
  { n: "02", ...rd.trusted },
];
---

<section class="section-y container-x" id="difference">
  <div class="max-w-2xl" data-reveal>
    <SectionLabel text="The Real Difference" />
    <h2 class="mt-5 text-h2">
      It's not about a website.<br />
      It's about what a website <span class="italic text-blue">does</span>.
    </h2>
  </div>

  <!-- Two paths, one craft: an editorial split with the brand mark as the
       pivot between them — not boxed cards. -->
  <div class="relative mt-16 grid gap-14 md:grid-cols-2 md:gap-0">
    <!-- center divider + pivot node (desktop) -->
    <div
      class="pointer-events-none absolute inset-y-1 left-1/2 hidden -translate-x-1/2 md:block"
      aria-hidden="true"
    >
      <span class="block h-full w-px bg-gradient-to-b from-transparent via-paper-300 to-transparent"></span>
      <span
        class="absolute left-1/2 top-1/2 flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-paper shadow-[0_8px_24px_-10px_rgba(11,12,16,0.35)] ring-1 ring-paper-300"
      >
        <svg viewBox="0 0 60 64" class="h-5 w-auto" aria-hidden="true">
          <rect x="32" y="12" width="18" height="46" rx="6" fill="var(--color-blue)"></rect>
          <rect x="6" y="26" width="18" height="32" rx="6" fill="var(--color-ink)"></rect>
          <circle cx="15" cy="11" r="9" fill="var(--color-blue-bright)"></circle>
        </svg>
      </span>
    </div>

    {
      paths.map((c, i) => (
        <article
          class="group relative md:px-12 lg:px-16 md:[&:first-child]:pl-0 md:[&:last-child]:pr-0"
          data-reveal
          data-reveal-delay={i * 120}
        >
          <div class="flex items-center gap-4">
            <span class="font-display text-5xl font-light leading-none text-ink/12 tabular-nums">
              {c.n}
            </span>
            <span class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-blue-deep">
              {c.tiers}
            </span>
          </div>

          <h3 class="mt-7 font-display text-[clamp(1.6rem,3vw,2.35rem)] font-medium leading-[1.1]">
            It's{" "}
            <span class="relative text-blue">
              "{c.tagline}"
              <span class="absolute -bottom-1 left-0 h-px w-0 bg-blue transition-[width] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:w-full" />
            </span>
          </h3>

          <p class="mt-6 max-w-md leading-relaxed text-ink-soft">{c.body}</p>
        </article>
      ))
    }
  </div>

  <p class="mx-auto mt-14 max-w-2xl text-center text-sm leading-relaxed text-ink-soft" data-reveal>
    {rd.note}
  </p>
</section>
