---
// ADDED SECTION (flagged): the "walking crowd" band — humour + conversion.
// Lightweight: pure CSS animation + inline SVG silhouettes, zero JS, zero images.
const people = Array.from({ length: 14 });
---

<section
  class="relative overflow-hidden bg-forest py-20 text-cream sm:py-28"
  aria-label="Your future customers are online"
>
  <!-- conversion message -->
  <div class="container-x relative z-10 text-center" data-reveal>
    <p class="eyebrow justify-center !text-terracotta-100 [&::before]:hidden">
      The walking truth
    </p>
    <h2 class="mx-auto mt-5 max-w-3xl text-cream text-[clamp(1.9rem,4.5vw,3.25rem)]">
      Right now, your future customers are walking past — straight to
      <span class="text-terracotta">whoever shows up online.</span>
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-cream/65">
      81% check the internet before they choose. Make sure the business they find
      is yours — not the one next door.
    </p>
  </div>

  <!-- walking crowd -->
  <div class="crowd pointer-events-none mt-14 flex w-max items-end gap-6 px-6 opacity-90">
    {
      [...people, ...people].map((_, i) => {
        const scale = 0.78 + ((i * 37) % 45) / 100; // pseudo-random heights
        const tone = i % 3 === 0 ? "#8aa39c" : i % 3 === 1 ? "#4b6460" : "#c35f3b";
        return (
          <svg
            class="walker shrink-0"
            style={`--d:${(i % 7) * 0.18}s; height:${Math.round(96 * scale)}px`}
            viewBox="0 0 40 96"
            fill={tone}
            aria-hidden="true"
            opacity={i % 3 === 2 ? "0.9" : "0.55"}
          >
            <circle cx="20" cy="11" r="9" />
            <rect x="11" y="24" width="18" height="40" rx="9" />
            <rect x="12" y="58" width="6" height="34" rx="3" />
            <rect x="22" y="58" width="6" height="34" rx="3" />
          </svg>
        );
      })
    }
  </div>
</section>

<style>
  .crowd {
    animation: walk 30s linear infinite;
  }
  @keyframes walk {
    to {
      transform: translateX(-50%);
    }
  }
  /* subtle up/down bob to simulate walking */
  .walker {
    animation: bob 0.7s ease-in-out infinite alternate;
    animation-delay: var(--d);
  }
  @keyframes bob {
    to {
      transform: translateY(-5px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .crowd,
    .walker {
      animation: none;
      transform: none;
    }
  }
</style>
