---
// The "walking crowd" moment — humour + conversion. Real canvas crowd of
// open-peeps walking along the base (Skiper39 CrowdCanvas), lazy-mounted.
import { CrowdCanvas } from "@/components/skiper/CrowdCanvas";
---

<section
  class="panel relative overflow-hidden bg-ink pt-24 text-paper sm:pt-28"
  aria-label="Your future customers are online"
>
  <!-- conversion message -->
  <div class="container-x relative z-10 text-center" data-reveal>
    <p class="eyebrow justify-center text-blue-soft [&::before]:hidden">
      The walking truth
    </p>
    <h2 class="mx-auto mt-5 max-w-3xl text-paper text-[clamp(1.9rem,4.5vw,3.25rem)]">
      Right now, your future customers are walking past — straight to
      <span class="text-blue-bright">whoever shows up online.</span>
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-paper/60">
      81% check the internet before they choose. Make sure the business they find
      is yours — not the one next door.
    </p>
  </div>

  <!-- walking crowd canvas -->
  <div class="relative mt-10 h-[clamp(280px,40vw,520px)] w-full">
    <CrowdCanvas
      client:idle
      src="/images/peeps/all-peeps.png"
      rows={15}
      cols={7}
      scale={1}
      className="absolute inset-0 h-full w-full"
    />
  </div>
</section>
