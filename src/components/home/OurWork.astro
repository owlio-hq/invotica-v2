---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import Button from "@/components/ui/Button.astro";
import WorkShowcase, { type WorkItem } from "@/components/skiper/WorkShowcase.tsx";

// Placeholder concepts (no real portfolio images yet). Brand-coloured cards.
const items: WorkItem[] = [
  { title: "Northwind Renovations", category: "Trades", from: "#214239", to: "#4b6460" },
  { title: "Harbour Law Group", category: "Legal", from: "#2c5648", to: "#16302a" },
  { title: "Maple Dental Studio", category: "Healthcare", from: "#c35f3b", to: "#ad4f2e" },
  { title: "Aster Consulting", category: "Consulting", from: "#4b6460", to: "#214239" },
  { title: "Riverside Café", category: "Hospitality", from: "#214239", to: "#c35f3b" },
];
---

<section class="section-y overflow-hidden" id="work">
  <div class="container-x">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <SectionLabel text="Our Work" />
        <h2 class="mt-5 max-w-md text-h2">Work we're proud of</h2>
        <p class="mt-4 max-w-lg text-ink-soft">
          We're putting together our portfolio. In the meantime, reach out and
          we'll show you exactly what we can build for your business.
        </p>
      </div>
      <Button href="/contact" variant="primary">Let's build yours</Button>
    </div>

    <p class="mt-8 text-xs uppercase tracking-[0.16em] text-sage" data-reveal>
      Drag to explore →
    </p>
  </div>

  <div class="container-x mt-6">
    <WorkShowcase items={items} client:visible />
  </div>
</section>
