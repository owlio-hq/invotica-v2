---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { process } from "@/data/site";
---

<section class="section-y bg-paper-200" id="process">
  <div class="container-x">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <SectionLabel text="Our Process" />
        <h2 class="mt-5 max-w-lg text-h2">
          How we bring your vision to life, <span class="italic text-terracotta">fast.</span>
        </h2>
      </div>
      <p class="max-w-sm text-ink-soft">
        A clear, four-step path from first conversation to a live site you're proud of.
      </p>
    </div>

    <ol class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        process.map((step, i) => (
          <li
            class="group relative flex flex-col rounded-3xl bg-cream p-7 ring-1 ring-cream-300 transition-all duration-500 hover:-translate-y-1.5 hover:bg-forest hover:text-cream"
            data-reveal
            data-reveal-delay={i * 90}
          >
            <span class="font-display text-5xl font-medium text-terracotta">{step.n}</span>
            <h3 class="mt-6 text-h3 transition-colors group-hover:text-cream">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft transition-colors group-hover:text-cream/70">
              {step.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
