---
import Kicker from "@/components/ui/Kicker.astro";
import { process } from "@/data/site";
---

<section class="section-y bg-paper-200" id="process">
  <div class="container-x">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <Kicker text="Our process" />
        <h2 class="mt-6 max-w-lg text-[clamp(2.2rem,1rem+4vw,4rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
          From first hello to live site, <span class="marker italic">fast.</span>
        </h2>
      </div>
      <p class="max-w-sm text-ink-soft">
        A clear, four-step path — no jargon, no surprises, no waiting months to see
        your site come to life.
      </p>
    </div>

    <!-- Connected timeline: the line draws in, the steps rise in sequence. -->
    <div class="relative mt-20">
      <!-- horizontal connector (desktop) -->
      <span
        class="absolute left-0 right-0 top-7 hidden h-px origin-left bg-ink/20 lg:block"
        data-fx="draw"
        aria-hidden="true"
      ></span>
      <!-- vertical connector (mobile / tablet) -->
      <span
        class="absolute bottom-4 left-7 top-4 w-px origin-top bg-ink/20 lg:hidden"
        aria-hidden="true"
      ></span>

      <ol class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6" data-fx="stagger">
        {
          process.map((step) => (
            <li class="group relative flex gap-5 lg:flex-col lg:gap-0">
              <span class="relative z-10 flex h-14 w-14 flex-none items-center justify-center rounded-2xl bg-ink font-display text-xl font-medium text-paper shadow-[0_12px_30px_-14px_rgba(11,12,16,0.7)] transition-colors duration-300 group-hover:bg-blue">
                {step.n}
              </span>
              <div class="lg:mt-7">
                <h3 class="text-h3">{step.title}</h3>
                <p class="mt-3 max-w-xs text-sm leading-relaxed text-ink-soft">{step.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
