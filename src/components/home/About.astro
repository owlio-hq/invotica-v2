---
import { about } from "@/data/site";
import Kicker from "@/components/ui/Kicker.astro";
---

<section class="section-y bg-paper-200" id="about">
  <div class="container-x grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4" data-reveal>
      <Kicker text="Founder's note" />
      <h2 class="mt-6 text-[clamp(2rem,1rem+3vw,3.25rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
        Why I started <span class="marker">Invotica.</span>
      </h2>
      <!-- DUMMY founder signoff — replace with the real name/story. -->
      <p class="mt-8 font-display text-lg italic text-blue">{about.signoff}</p>
    </div>

    <div class="lg:col-span-7 lg:col-start-6">
      <div class="flex flex-col gap-6">
        {
          about.paragraphs.map((p, i) => (
            <p
              class:list={[
                "leading-relaxed text-ink-soft",
                i === 0 && "text-lead text-ink",
              ]}
              data-reveal
              data-reveal-delay={i * 80}
            >
              {p}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>
