---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { about } from "@/data/site";
---

<section class="section-y bg-cream-200/50" id="about">
  <div class="container-x grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4" data-reveal>
      <SectionLabel text="Our Story" />
      <h2 class="mt-5 text-h2">{about.headline}</h2>
      <!-- DUMMY founder signoff — replace with the real name/story. -->
      <p class="mt-8 font-display text-lg italic text-forest">{about.signoff}</p>
    </div>

    <div class="lg:col-span-7 lg:col-start-6">
      <div class="flex flex-col gap-6">
        {
          about.paragraphs.map((p, i) => (
            <p
              class:list={[
                "leading-relaxed text-ink-soft",
                i === 0 && "text-lead text-ink",
              ]}
              data-reveal
              data-reveal-delay={i * 80}
            >
              {p}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>
