---
import { numbers } from "@/data/site";

// Parse "81%" → { value: 81, suffix: "%" } for count-up; leave "2x" static.
function parse(stat: string) {
  const m = stat.match(/^(\d+)(\D*)$/);
  return m ? { value: Number(m[1]), suffix: m[2], animate: true } : { animate: false };
}
---

<section class="section-y relative overflow-hidden bg-ink text-paper" id="numbers">
  <div
    class="pointer-events-none absolute -right-24 -top-10 h-80 w-80 rounded-full bg-blue/20 blur-[120px]"
    aria-hidden="true"
  ></div>

  <div class="container-x relative">
    <div class="max-w-xl" data-reveal>
      <span class="sticker rotate-1">★ The numbers</span>
      <h2 class="mt-7 text-paper text-[clamp(2.2rem,1rem+4vw,4rem)] font-light leading-[1.02] tracking-tight">
        The numbers don't <span class="marker">lie.</span>
      </h2>
    </div>

    <!-- main stats -->
    <div class="mt-16 grid gap-10 md:grid-cols-2" data-fx="stagger">
      {
        numbers.main.map((n) => {
          const p = parse(n.stat);
          return (
            <div class="border-t border-white/15 pt-8">
              <div class="font-display text-[clamp(3.5rem,9vw,6.5rem)] font-medium leading-none text-paper">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-5 max-w-md leading-relaxed text-paper/60">{n.body}</p>
            </div>
          );
        })
      }
    </div>

    <!-- supporting stats -->
    <div class="mt-14 grid gap-6 border-t border-white/15 pt-10 sm:grid-cols-3" data-fx="stagger">
      {
        numbers.supporting.map((n) => {
          const p = parse(n.stat);
          return (
            <div>
              <div class="font-display text-4xl font-medium text-lime">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-paper/55">{n.body}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
