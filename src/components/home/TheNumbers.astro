---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { numbers } from "@/data/site";

// Parse "81%" → { value: 81, suffix: "%" } for count-up; leave "2x" static.
function parse(stat: string) {
  const m = stat.match(/^(\d+)(\D*)$/);
  return m ? { value: Number(m[1]), suffix: m[2], animate: true } : { animate: false };
}
---

<section class="section-y bg-forest text-cream" id="numbers">
  <div class="container-x">
    <div class="max-w-md" data-reveal>
      <SectionLabel text="The Numbers" class="!text-terracotta-100" />
      <h2 class="mt-5 text-cream text-h2">The numbers don't lie.</h2>
    </div>

    <!-- main stats -->
    <div class="mt-14 grid gap-10 md:grid-cols-2">
      {
        numbers.main.map((n, i) => {
          const p = parse(n.stat);
          return (
            <div class="border-t border-cream/15 pt-8" data-reveal data-reveal-delay={i * 100}>
              <div class="font-display text-[clamp(3.5rem,9vw,6rem)] font-medium leading-none text-cream">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-5 max-w-md leading-relaxed text-cream/65">{n.body}</p>
            </div>
          );
        })
      }
    </div>

    <!-- supporting stats -->
    <div class="mt-14 grid gap-6 border-t border-cream/15 pt-10 sm:grid-cols-3">
      {
        numbers.supporting.map((n, i) => {
          const p = parse(n.stat);
          return (
            <div data-reveal data-reveal-delay={i * 80}>
              <div class="font-display text-4xl font-medium text-terracotta">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-cream/60">{n.body}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
