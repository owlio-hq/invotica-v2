---
import Kicker from "@/components/ui/Kicker.astro";
import { numbers } from "@/data/site";

// Parse "81%" → { value: 81, suffix: "%" } for count-up; leave "2x" static.
function parse(stat: string) {
  const m = stat.match(/^(\d+)(\D*)$/);
  return m ? { value: Number(m[1]), suffix: m[2], animate: true } : { animate: false };
}
---

<section class="section-y relative overflow-hidden bg-blue text-white" id="numbers">
  <div
    class="pointer-events-none absolute -right-24 -top-10 h-80 w-80 rounded-full bg-white/10 blur-[120px]"
    aria-hidden="true"
  ></div>

  <div class="container-x relative">
    <div class="max-w-xl" data-reveal>
      <Kicker text="The numbers" />
      <h2 class="mt-6 text-white text-[clamp(2.2rem,1rem+4vw,4rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
        The numbers don't <span class="marker">lie.</span>
      </h2>
    </div>

    <!-- main stats -->
    <div class="mt-16 grid gap-10 md:grid-cols-2">
      {
        numbers.main.map((n, i) => {
          const p = parse(n.stat);
          return (
            <div class="border-t border-white/20 pt-8" data-reveal data-reveal-delay={i * 110}>
              <div class="font-display text-[clamp(3.5rem,9vw,6.5rem)] font-semibold leading-none text-white">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-5 max-w-md leading-relaxed text-white/70">{n.body}</p>
            </div>
          );
        })
      }
    </div>

    <!-- supporting stats -->
    <div class="mt-14 grid gap-6 border-t border-white/20 pt-10 sm:grid-cols-3">
      {
        numbers.supporting.map((n, i) => {
          const p = parse(n.stat);
          return (
            <div data-reveal data-reveal-delay={i * 90}>
              <div class="font-display text-4xl font-semibold text-lime">
                {p.animate ? (
                  <span data-count={p.value} data-suffix={p.suffix}>
                    {n.stat}
                  </span>
                ) : (
                  n.stat
                )}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-white/65">{n.body}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
