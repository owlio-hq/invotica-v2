---
import Button from "@/components/ui/Button.astro";

const phrases = [
  "found online.",
  "chosen first.",
  "trusted instantly.",
  "impossible to ignore.",
];
---

<section class="relative overflow-hidden">
  <!-- floating brand shapes (decorative, lightweight SVG) -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <span class="shape shape-a absolute h-24 w-24 rounded-full bg-terracotta/15"></span>
    <span class="shape shape-b absolute h-40 w-16 rounded-[2rem] bg-sage/15"></span>
    <span class="shape shape-c absolute h-28 w-12 rounded-[1.5rem] bg-forest/10"></span>
    <div
      class="absolute inset-0 opacity-[0.5]"
      style="background-image:radial-gradient(circle at 1px 1px, var(--color-cream-300) 1px, transparent 0);background-size:34px 34px;mask-image:radial-gradient(ellipse 70% 60% at 50% 35%, #000 30%, transparent 75%)"
    >
    </div>
  </div>

  <div class="container-x flex min-h-[92svh] flex-col justify-center pt-28 pb-16">
    <p
      class="mb-8 inline-flex w-fit items-center gap-2 rounded-full bg-cream-200 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-forest ring-1 ring-cream-300"
      data-reveal
    >
      <span class="h-1.5 w-1.5 rounded-full bg-terracotta"></span>
      Design. Build. Launch.
    </p>

    <h1 class="max-w-[16ch] text-display" data-reveal data-reveal-delay="80">
      Your business deserves to be{" "}
      <span class="relative whitespace-nowrap text-terracotta">
        <span data-typewriter data-phrases={JSON.stringify(phrases)}>found online.</span
        ><span class="tw-caret" aria-hidden="true"></span>
      </span>
    </h1>

    <p class="mt-7 max-w-xl text-lead text-ink-soft" data-reveal data-reveal-delay="160">
      Custom websites for Canadian businesses — built fast, built to convert.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4" data-reveal data-reveal-delay="240">
      <Button href="/contact" size="lg" variant="primary">Start a project</Button>
      <Button href="/pricing" size="lg" variant="ghost">See our plans</Button>
    </div>

    <p class="mt-5 text-sm text-ink-soft/80" data-reveal data-reveal-delay="300">
      Not sure which plan? <a href="/contact" class="font-medium text-forest underline decoration-terracotta/40 underline-offset-4 hover:decoration-terracotta">Talk to us.</a>
    </p>
  </div>

  <!-- bottom sweep line -->
  <div class="border-y border-cream-300 bg-cream-200/60">
    <div class="container-x flex items-center gap-4 py-5">
      <span class="hidden h-2 w-2 shrink-0 rounded-full bg-terracotta sm:block"></span>
      <p class="text-base text-ink-soft sm:text-lg">
        <span class="font-medium text-ink">Your competitor's website is already getting your clients.</span>
        Let's fix that.
      </p>
    </div>
  </div>
</section>

<style>
  .tw-caret {
    display: inline-block;
    width: 2px;
    height: 0.95em;
    margin-left: 2px;
    translate: 0 0.1em;
    background: currentColor;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to {
      opacity: 0;
    }
  }

  .shape {
    animation: float 9s ease-in-out infinite;
  }
  .shape-a {
    top: 18%;
    right: 12%;
    animation-delay: -1s;
  }
  .shape-b {
    top: 34%;
    right: 26%;
    animation-delay: -3.5s;
  }
  .shape-c {
    bottom: 22%;
    right: 18%;
    animation-delay: -6s;
  }
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-18px) rotate(4deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .shape,
    .tw-caret {
      animation: none;
    }
  }
</style>
