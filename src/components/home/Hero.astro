---
import Button from "@/components/ui/Button.astro";

const phrases = ["found online.", "chosen first.", "trusted fast.", "unmissable."];
const sizer  = "unmissable.";

const stats = [
  { value: "14",   label: "sites launched" },
  { value: "100%", label: "client retention" },
  { value: "2 wk", label: "avg. delivery" },
];
---

<section class="hero relative isolate flex min-h-svh flex-col overflow-hidden">
  <!-- subtle radial glow behind the headline -->
  <div
    class="pointer-events-none absolute left-1/2 top-[38%] h-[520px] w-[680px] -translate-x-1/2 -translate-y-1/2 rounded-[50%] bg-blue/20 blur-[120px]"
    aria-hidden="true"
  ></div>

  <!-- content: vertically centred with nav offset; recedes as you scroll past -->
  <div
    data-fx="hero"
    class="container-x relative z-10 flex flex-1 flex-col items-center justify-center pb-16 pt-32 text-center"
  >
    <!-- kicker -->
    <div class="mb-6 inline-flex items-center gap-3 text-[0.78rem] sm:text-sm" data-reveal>
      <svg
        class="kick-star h-4 w-4 text-lime"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 2c.5 5 5 9.5 10 10-5 .5-9.5 5-10 10-.5-5-5-9.5-10-10 5-.5 9.5-5 10-10Z" />
      </svg>
      <span class="uppercase tracking-[0.18em] text-paper/55">Now booking</span>
      <span class="h-3.5 w-px bg-paper/20"></span>
      <span class="uppercase tracking-[0.18em] text-blue-soft">2026 projects</span>
    </div>

    <!-- headline -->
    <h1
      class="max-w-5xl text-[clamp(2.8rem,1rem+5.5vw,7rem)] font-light leading-[1.03] tracking-tight"
      data-reveal
      data-reveal-delay="60"
    >
      <span class="block text-paper">Your business deserves to be</span>
      <!-- typewriter slot: invisible sizer prevents reflow -->
      <span class="tw-slot">
        <span class="tw-sizer text-blue-bright" aria-hidden="true">{sizer}</span>
        <span class="tw-anim text-blue-bright">
          <span data-typewriter data-phrases={JSON.stringify(phrases)}>found online.</span
          ><span class="tw-caret" aria-hidden="true"></span>
        </span>
      </span>
    </h1>

    <!-- subtext -->
    <p
      class="mt-6 max-w-lg text-[1.05rem] leading-relaxed text-paper/60"
      data-reveal
      data-reveal-delay="120"
    >
      Custom websites for Canadian businesses — built fast, built to convert.
    </p>

    <!-- CTAs -->
    <div
      class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-4"
      data-reveal
      data-reveal-delay="180"
    >
      <Button href="/contact" size="lg" variant="primary">Start a project</Button>
      <a
        href="/pricing"
        class="text-sm font-medium text-paper/70 underline decoration-blue/35 decoration-1 underline-offset-[6px] transition-colors hover:text-paper hover:decoration-blue-bright"
      >
        Not sure which plan?
      </a>
    </div>

    <!-- stat strip -->
    <div
      class="mt-12 flex items-stretch justify-center gap-1 sm:gap-px"
      data-reveal
      data-reveal-delay="260"
    >
      {
        stats.map((s, i) => (
          <>
            <div class="stat-card">
              <span class="block text-[clamp(1.6rem,3vw,2.4rem)] font-light tabular-nums text-paper">
                {s.value}
              </span>
              <span class="mt-0.5 block text-[0.72rem] uppercase tracking-[0.14em] text-paper/45">
                {s.label}
              </span>
            </div>
            {i < stats.length - 1 && (
              <div class="h-12 w-px self-center bg-paper/10" aria-hidden="true" />
            )}
          </>
        ))
      }
    </div>

    <!-- subtle scroll cue -->
    <a
      href="#problem"
      class="scroll-hint mx-auto mt-12 flex w-fit flex-col items-center gap-2 text-paper/40 transition-colors hover:text-paper/75"
      aria-label="Scroll down"
    >
      <span class="text-[0.62rem] uppercase tracking-[0.22em]">Scroll</span>
      <span class="scroll-mouse"><span class="scroll-dot"></span></span>
    </a>
  </div>

  <!-- bottom marquee strip -->
  <div class="marquee-strip relative z-10 w-full overflow-hidden border-t border-paper/8 py-4">
    <div class="marquee-track inline-flex w-max gap-10 whitespace-nowrap">
      {
        Array(3).fill([
          "Web Design", "Branding", "SEO", "Copywriting",
          "E-Commerce", "Landing Pages", "Maintenance",
        ]).flat().map((t) => (
          <span class="text-[0.7rem] uppercase tracking-[0.22em] text-paper/30">
            {t} <span class="mx-4 text-paper/15" aria-hidden="true">·</span>
          </span>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  /* Typewriter slot — invisible sizer freezes the line width */
  .tw-slot {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .tw-sizer {
    visibility: hidden;
  }
  .tw-anim {
    position: absolute;
    left: 0;
    top: 0;
    white-space: nowrap;
  }
  .tw-caret {
    display: inline-block;
    width: 2px;
    height: 0.88em;
    margin-left: 2px;
    translate: 0 0.1em;
    background: currentColor;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to { opacity: 0; }
  }

  .kick-star {
    transform-origin: center;
    animation: kick-spin 7s linear infinite;
  }
  @keyframes kick-spin {
    to { transform: rotate(360deg); }
  }

  /* Stat cards */
  .stat-card {
    padding: 0.5rem 1rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .stat-card {
      padding: 1.1rem 2.4rem;
    }
  }

  /* Marquee */
  .marquee-track {
    animation: marquee 28s linear infinite;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  /* Scroll cue mouse */
  .scroll-mouse {
    position: relative;
    display: block;
    width: 22px;
    height: 34px;
    border: 1.5px solid currentColor;
    border-radius: 11px;
    opacity: 0.7;
  }
  .scroll-dot {
    position: absolute;
    left: 50%;
    top: 7px;
    width: 3px;
    height: 6px;
    margin-left: -1.5px;
    border-radius: 2px;
    background: currentColor;
    animation: scroll-dot 1.7s var(--ease-out-expo) infinite;
  }
  @keyframes scroll-dot {
    0% { opacity: 0; transform: translateY(0); }
    30% { opacity: 1; }
    70% { opacity: 1; transform: translateY(10px); }
    100% { opacity: 0; transform: translateY(12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .tw-caret,
    .kick-star,
    .marquee-track,
    .scroll-dot {
      animation: none;
    }
  }
</style>
