---
import Button from "@/components/ui/Button.astro";

const phrases = ["found online.", "chosen first.", "trusted fast.", "unmissable."];
const sizer = "unmissable.";

const sites = [
  { name: "Maple & Co. Dental", tag: "Clinic" },
  { name: "Northside Café", tag: "Hospitality" },
  { name: "Apex Legal", tag: "Professional" },
  { name: "GreenLeaf Landscaping", tag: "Trades" },
  { name: "Harbour Realty", tag: "Real Estate" },
  { name: "Lumen Studio", tag: "Creative" },
];
const track = [...sites, ...sites];
---

<!--
  Hero layout: ink background, blue PILL in the centre (not ink caps).
  Content zones sit absolutely above/below the pill so their height is
  independent of the pill size — no overflow into the blue band.

  Pill:  top 40% → 62%  (22% tall, centred at 51%)
  Top:   0  → 40%       (kicker + headline + CTAs — justify-end so copy sits above arc)
  Bot:   62% → 100%     (tagline — 38%)
-->
<section class="hero relative isolate overflow-hidden min-h-svh">
  <!-- ── Ink base ── -->
  <!-- Blue pill lens -->
  <div class="lens" aria-hidden="true">
    <!-- inner glow -->
    <div
      class="absolute left-1/2 top-1/2 h-[70%] w-[50%] -translate-x-1/2 -translate-y-1/2 rounded-[50%] bg-white/12 blur-2xl"
    ></div>

    <!-- sliding client-site cards, centred in the pill -->
    <div class="port-mask absolute inset-x-0 top-1/2 -translate-y-1/2">
      <div class="port-track flex w-max items-center gap-4 px-4">
        {
          track.map((s, i) => (
            <div class="port-card" aria-hidden={i >= sites.length ? "true" : "false"}>
              <span class="port-win">
                <span></span>
                <span></span>
                <span></span>
              </span>
              <span class="flex min-w-0 flex-col">
                <span class="truncate font-medium text-white">{s.name}</span>
                <span class="mt-0.5 flex items-center gap-2 text-xs text-white/65">
                  <span>{s.tag}</span>
                  <span class="inline-flex items-center gap-1">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-300" />
                     Live
                  </span>
                </span>
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Hairline ellipse tracing the lens edge -->
  <svg
    class="pointer-events-none absolute inset-0 z-20 h-full w-full"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <ellipse
      cx="50%"
      cy="57%"
      rx="58%"
      ry="7%"
      fill="none"
      stroke="rgba(255,255,255,0.14)"
      stroke-width="1"></ellipse>
  </svg>

  <!-- Centre line + brand mark pivot (at lens centre) -->
  <div class="absolute left-1/2 top-0 z-20 h-full w-px -translate-x-1/2 bg-white/10"></div>
  <div
    class="pivot absolute left-1/2 z-40 flex h-[4.5rem] w-[4.5rem] -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-[1.2rem] bg-paper shadow-[0_12px_40px_-12px_rgba(11,12,16,0.75)]"
  >
    <svg viewBox="0 0 60 64" class="h-9 w-auto" aria-hidden="true">
      <rect x="32" y="12" width="18" height="46" rx="6" fill="var(--color-blue)"></rect>
      <rect x="6" y="26" width="18" height="32" rx="6" fill="var(--color-ink)"></rect>
      <circle cx="15" cy="11" r="9" fill="var(--color-blue-bright)"></circle>
    </svg>
  </div>

  <!-- TOP ZONE: absolutely pinned above the pill, content justified to bottom so it sits just above the arc -->
  <div
    class="top-zone absolute inset-x-0 top-0 z-30 flex flex-col items-center justify-end px-4 pb-8 text-center"
  >
    <div
      class="mb-3 inline-flex items-center gap-3 text-[0.78rem] sm:text-sm"
      data-reveal
    >
      <svg
        class="kick-star h-4 w-4 text-blue-bright"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 2c.5 5 5 9.5 10 10-5 .5-9.5 5-10 10-.5-5-5-9.5-10-10 5-.5 9.5-5 10-10Z"
        ></path>
      </svg>
      <span class="uppercase tracking-[0.18em] text-paper/65">Now booking</span>
      <span class="h-3.5 w-px bg-paper/25"></span>
      <span class="uppercase tracking-[0.18em] text-blue-soft">2026 projects</span>
    </div>

    <h1
      class="max-w-4xl text-[clamp(2rem,0.8rem+3vw,4.8rem)] font-light leading-[1.05] tracking-tight"
      data-reveal
      data-reveal-delay="80"
    >
      <span class="block">Your business deserves to be</span>
      <span class="tw-slot">
        <span class="tw-sizer" aria-hidden="true">{sizer}</span>
        <span class="tw-anim text-blue-bright">
          <span data-typewriter data-phrases={JSON.stringify(phrases)}>found online.</span
          ><span class="tw-caret" aria-hidden="true"></span>
        </span>
      </span>
    </h1>

    <p
      class="mt-3 max-w-md text-base leading-relaxed text-paper/70"
      data-reveal
      data-reveal-delay="160"
    >
      Custom websites for Canadian businesses — built fast, built to convert.
    </p>

    <div
      class="mt-5 flex flex-wrap items-center justify-center gap-x-7 gap-y-4"
      data-reveal
      data-reveal-delay="240"
    >
      <Button href="/contact" size="lg" variant="primary">Start a project</Button>
      <a
        href="/pricing"
        class="text-sm font-medium text-paper/80 underline decoration-blue/40 decoration-1 underline-offset-[6px] transition-colors hover:text-white hover:decoration-blue-bright"
      >
        Not sure which plan?
      </a>
    </div>
  </div>

  <!-- BOTTOM ZONE: absolutely pinned below the pill -->
  <div
    class="bot-zone absolute inset-x-0 bottom-0 z-30 flex items-center justify-center px-4 pt-6 text-center"
    data-reveal
  >
    <p
      class="mx-auto max-w-2xl text-[clamp(1rem,0.4rem+1.5vw,1.35rem)] font-light leading-snug text-paper/90"
    >
      No templates. No hostage situations — just a website<span class="text-blue-bright">
        that does the selling.</span
      >
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--color-ink);
    color: var(--color-paper);
  }

  /* ── Pill lens ── */
  /* Positioned as absolute with percentage top/bottom so the height is
     fully independent of page content. left/right overflow controls arc
     curvature: less overflow = more dramatic visible curve. */
  .lens {
    position: absolute;
    top: 50%;
    bottom: 36%;
    left: -8%;
    right: -8%;
    border-radius: 50%;
    background: var(--color-blue);
    z-index: 1;
    overflow: hidden;
  }

  /* Brand mark sits at the vertical centre of the pill (50% + 7% = 57%) */
  .pivot {
    top: 57%;
  }

  /* Top content zone: 50% of viewport, copy justified to bottom */
  .top-zone {
    height: 50%;
  }

  /* Bottom content zone: 36% of viewport from the bottom */
  .bot-zone {
    height: 36%;
  }

  /* ── Typewriter ── */
  .tw-slot {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .tw-sizer {
    visibility: hidden;
  }
  .tw-anim {
    position: absolute;
    left: 0;
    top: 0;
    white-space: nowrap;
  }
  .tw-caret {
    display: inline-block;
    width: 2px;
    height: 0.92em;
    margin-left: 3px;
    translate: 0 0.1em;
    background: currentColor;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to {
      opacity: 0;
    }
  }

  .kick-star {
    transform-origin: center;
    animation: kick-spin 7s linear infinite;
  }
  @keyframes kick-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Cards track ── */
  .port-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 10%,
      #000 90%,
      transparent
    );
  }
  .port-track {
    animation: port-slide 40s linear infinite;
  }
  .port-track:hover {
    animation-play-state: paused;
  }
  @keyframes port-slide {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .port-card {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: 15rem;
    flex: 0 0 auto;
    padding: 0.75rem 0.95rem;
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.11);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(4px);
  }
  .port-win {
    display: inline-flex;
    gap: 3px;
    align-items: center;
    height: 2rem;
    width: 2rem;
    justify-content: center;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.16);
    flex: 0 0 auto;
  }
  .port-win span {
    height: 4px;
    width: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .tw-caret,
    .kick-star,
    .port-track {
      animation: none;
    }
  }
</style>
