---
import Button from "@/components/ui/Button.astro";

// Kept short + similar width so the reserved slot never reflows the headline.
const phrases = ["found online.", "chosen first.", "trusted fast.", "unmissable."];
// Widest phrase reserves the slot box (invisible sizer below).
const sizer = "trusted fast.";
---

<section class="relative isolate overflow-hidden on-ink">
  <!-- Arc "portal" motif: concentric thin rings + soft blue glow (decorative). -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="grid-faint absolute inset-0 opacity-60"
      style="mask-image:radial-gradient(ellipse 75% 60% at 50% 38%, #000 30%, transparent 78%)"></div>

    <div class="absolute left-1/2 top-[58%] -z-10 h-[120vmax] w-[120vmax] -translate-x-1/2 -translate-y-1/4"
      aria-hidden="true">
      <svg viewBox="0 0 1000 1000" class="h-full w-full" fill="none" preserveAspectRatio="xMidYMid slice">
        <g stroke="var(--color-blue)" stroke-opacity="0.16">
          <circle cx="500" cy="500" r="200" />
          <circle cx="500" cy="500" r="300" />
          <circle cx="500" cy="500" r="410" />
          <circle cx="500" cy="500" r="500" stroke-opacity="0.10" />
        </g>
      </svg>
    </div>

    <!-- centred blue glow -->
    <div class="absolute left-1/2 top-[34%] h-[42vmax] w-[42vmax] -translate-x-1/2 -translate-y-1/2 rounded-full"
      style="background:radial-gradient(circle, color-mix(in srgb, var(--color-blue) 40%, transparent), transparent 62%);filter:blur(30px);opacity:0.5"></div>
  </div>

  <div class="container-x flex min-h-[94svh] flex-col items-center justify-center pt-32 pb-40 text-center">
    <div class="mb-10 inline-flex items-center gap-3 text-[0.78rem] sm:text-sm" data-reveal>
      <svg class="kick-star h-4 w-4 text-blue-bright" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2c.5 5 5 9.5 10 10-5 .5-9.5 5-10 10-.5-5-5-9.5-10-10 5-.5 9.5-5 10-10Z" />
      </svg>
      <span class="uppercase tracking-[0.18em] text-paper/65">Now booking</span>
      <span class="h-3.5 w-px bg-paper/25"></span>
      <span class="uppercase tracking-[0.18em] text-blue-soft">2026 projects</span>
    </div>

    <h1 class="text-display font-light" data-reveal data-reveal-delay="80">
      <span class="block">Your business</span>
      <span class="block">deserves to be</span>
      <span class="tw-slot">
        <span class="tw-sizer" aria-hidden="true">{sizer}</span>
        <span class="tw-anim text-blue-bright">
          <span data-typewriter data-phrases={JSON.stringify(phrases)}>found online.</span
          ><span class="tw-caret" aria-hidden="true"></span>
        </span>
      </span>
    </h1>

    <p class="mt-8 max-w-xl text-lead text-paper/70" data-reveal data-reveal-delay="160">
      Custom websites for Canadian businesses — built fast, built to convert.
      No templates. No hostage situations.
    </p>

    <div class="mt-11 flex flex-wrap items-center justify-center gap-4" data-reveal data-reveal-delay="240">
      <Button href="/contact" size="lg" variant="primary">Start a project</Button>
      <Button href="/pricing" size="lg" variant="ghostDark">See our plans</Button>
    </div>

    <p class="mt-6 text-sm text-paper/55" data-reveal data-reveal-delay="300">
      Not sure which plan?{" "}
      <a href="/contact" class="font-medium text-blue-soft underline decoration-blue/40 underline-offset-4 transition-colors hover:decoration-blue-bright hover:text-white">Talk to us.</a>
    </p>
  </div>

  <!-- Curved arc transition into the next (light) section — no straight edges. -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0" aria-hidden="true">
    <svg viewBox="0 0 1440 140" preserveAspectRatio="none" class="block h-[8vw] min-h-[64px] w-full">
      <path d="M0,140 L0,96 Q720,-24 1440,96 L1440,140 Z" fill="var(--color-blue-deep)"></path>
    </svg>
  </div>
</section>

<style>
  /* Typed word sits in a fixed-size slot (reserved by an invisible sizer) so the
     headline height NEVER changes as phrases cycle — no layout shift. */
  .tw-slot {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .tw-sizer {
    visibility: hidden;
  }
  .tw-anim {
    position: absolute;
    left: 0;
    top: 0;
    white-space: nowrap;
  }

  .tw-caret {
    display: inline-block;
    width: 2px;
    height: 0.92em;
    margin-left: 3px;
    translate: 0 0.1em;
    background: currentColor;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to {
      opacity: 0;
    }
  }

  /* Slowly rotating sparkle in the kicker — a small crafted detail. */
  .kick-star {
    transform-origin: center;
    animation: kick-spin 7s linear infinite;
  }
  @keyframes kick-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tw-caret,
    .kick-star {
      animation: none;
    }
  }
</style>
