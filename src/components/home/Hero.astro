---
const phrases = ["found online.", "chosen first.", "trusted fast.", "unmissable."];
const sizer = "unmissable.";

const stats = [
  { value: "14", label: "sites launched" },
  { value: "100%", label: "client retention" },
  { value: "2 wk", label: "avg. delivery" },
];
---

<section class="hero relative isolate flex min-h-svh flex-col overflow-hidden">
  <!-- grid texture on the blue -->
  <div class="hero-grid-bg pointer-events-none absolute inset-0 z-0" aria-hidden="true"></div>
  <!-- soft bloom -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/3 h-[520px] w-[680px] -translate-x-1/2 rounded-[50%] bg-white/10 blur-[130px]"
    aria-hidden="true"
  ></div>

  <!-- floating frosted cards (desktop) -->
  <div
    data-fx="parallax"
    data-fx-speed="0.12"
    class="float-card absolute right-[6%] top-[24%] z-10 hidden w-56 -rotate-3 rounded-3xl bg-white/12 p-4 ring-1 ring-white/25 backdrop-blur-md lg:block"
    aria-hidden="true"
  >
    <div class="flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-lime text-sm font-bold text-lime-deep">M</span>
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-white">Maple & Co. Dental</p>
        <p class="text-xs text-white/65">Clinic · Live</p>
      </div>
    </div>
    <div class="mt-3 flex items-center justify-between rounded-xl bg-white/10 px-3 py-2">
      <span class="text-xs text-white/70">Calls this month</span>
      <span class="text-sm font-semibold text-lime">+38%</span>
    </div>
  </div>

  <div
    data-fx="parallax"
    data-fx-speed="0.2"
    class="float-card absolute left-[5%] top-[52%] z-10 hidden w-52 rotate-2 rounded-3xl bg-white/12 p-4 ring-1 ring-white/25 backdrop-blur-md lg:block"
    aria-hidden="true"
  >
    <div class="flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-white text-sm font-bold text-blue">N</span>
      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-white">Northside Café</p>
        <p class="text-xs text-white/65">Hospitality · Live</p>
      </div>
    </div>
    <div class="mt-3 h-1.5 w-full overflow-hidden rounded-full bg-white/15">
      <div class="h-full w-3/4 rounded-full bg-lime"></div>
    </div>
  </div>

  <!-- rotating lime badge (desktop) — links to the contact form -->
  <a
    href="/contact"
    aria-label="Get a free quote"
    class="badge-spin absolute bottom-[24%] right-[8%] z-10 hidden h-28 w-28 place-items-center rounded-full bg-lime text-lime-deep lg:grid"
  >
    <svg viewBox="0 0 100 100" class="absolute inset-0 h-full w-full">
      <defs>
        <path id="heroBadgeArc" d="M50,50 m-36,0 a36,36 0 1,1 72,0 a36,36 0 1,1 -72,0"></path>
      </defs>
      <text class="fill-lime-deep text-[9.5px] font-bold uppercase">
        <textPath href="#heroBadgeArc" startOffset="0" textLength="214" lengthAdjust="spacing">Free quote · Get started ·</textPath>
      </text>
    </svg>
    <span class="text-2xl font-bold">↗</span>
  </a>

  <!-- content -->
  <div
    class="container-x relative z-20 flex flex-1 flex-col items-center justify-center pb-14 pt-32 text-center"
  >
    <div class="hero-in mb-7 inline-flex items-center gap-3 text-sm">
      <svg class="kick-star h-4 w-4 text-lime" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2c.5 5 5 9.5 10 10-5 .5-9.5 5-10 10-.5-5-5-9.5-10-10 5-.5 9.5-5 10-10Z" />
      </svg>
      <span class="uppercase tracking-[0.2em] text-white/75">Now booking</span>
      <span class="h-3.5 w-px bg-white/30"></span>
      <span class="uppercase tracking-[0.2em] text-lime">2026 projects</span>
    </div>

    <h1
      class="hero-in max-w-5xl text-[clamp(2.9rem,1rem+6vw,7rem)] font-semibold leading-[0.98] tracking-[-0.02em] text-white"
      style="animation-delay:60ms"
    >
      <span class="block">Your business</span>
      <span class="block">deserves to be</span>
      <span class="tw-slot">
        <span class="tw-sizer" aria-hidden="true">{sizer}</span>
        <span class="tw-anim text-lime">
          <span data-typewriter data-phrases={JSON.stringify(phrases)}>found online.</span
          ><span class="tw-caret" aria-hidden="true"></span>
        </span>
        <!-- squiggle underline under the rotating word -->
        <svg class="tw-underline" viewBox="0 0 220 14" fill="none" preserveAspectRatio="none" aria-hidden="true">
          <path d="M4 9 Q 30 2, 58 8 T 114 8 T 170 8 T 216 7" stroke="var(--color-lime)" stroke-width="5" stroke-linecap="round" />
        </svg>
      </span>
    </h1>

    <p class="hero-in mt-6 max-w-lg text-[1.05rem] leading-relaxed text-white/75" style="animation-delay:120ms">
      Custom websites for Canadian businesses — built fast, built to convert.
    </p>

    <div class="hero-in mt-8 flex flex-wrap items-center justify-center gap-4" style="animation-delay:180ms">
      <a href="/contact" class="btn btn-light btn-lg">
        Get a free quote
        <span class="btn-arrow" aria-hidden="true">↗</span>
      </a>
      <a href="/pricing" class="btn btn-lime btn-lg">
        See pricing
        <span class="btn-arrow" aria-hidden="true">↗</span>
      </a>
    </div>

    <!-- stat strip -->
    <div class="hero-in mt-12 flex items-stretch justify-center gap-1 sm:gap-px" style="animation-delay:260ms">
      {
        stats.map((s, i) => (
          <>
            <div class="stat-card">
              <span class="block text-[clamp(1.5rem,3vw,2.2rem)] font-semibold tabular-nums text-white">{s.value}</span>
              <span class="mt-0.5 block text-[0.7rem] uppercase tracking-[0.14em] text-white/55">{s.label}</span>
            </div>
            {i < stats.length - 1 && <div class="h-10 w-px self-center bg-white/20" aria-hidden="true" />}
          </>
        ))
      }
    </div>
  </div>

  <!-- scroll cue -->
  <a
    href="#problem"
    class="scroll-hint absolute bottom-6 left-1/2 z-20 flex -translate-x-1/2 flex-col items-center gap-2 text-white/55 transition-colors hover:text-white"
    aria-label="Scroll down"
  >
    <span class="scroll-mouse"><span class="scroll-dot"></span></span>
  </a>
</section>

<style>
  .hero {
    background: var(--color-blue);
    color: #fff;
  }

  /* Above-the-fold entrance — pure CSS so it paints without waiting for JS
     (no data-reveal here, which is what tanked Speed Index). Staggered via
     inline animation-delay on each element. */
  .hero-in {
    opacity: 0;
    animation: hero-in 0.6s var(--ease-out-expo) both;
  }
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-grid-bg {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 55%, transparent 100%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 55%, transparent 100%);
  }

  /* Typewriter slot */
  .tw-slot {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .tw-sizer {
    visibility: hidden;
  }
  .tw-anim {
    position: absolute;
    left: 0;
    top: 0;
    white-space: nowrap;
  }
  .tw-underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.18em;
    width: 100%;
    height: 0.32em;
  }
  .tw-caret {
    display: inline-block;
    width: 3px;
    height: 0.86em;
    margin-left: 3px;
    translate: 0 0.08em;
    background: currentColor;
    animation: blink 1s steps(2, start) infinite;
  }
  @keyframes blink {
    to { opacity: 0; }
  }

  .kick-star {
    transform-origin: center;
    animation: kick-spin 7s linear infinite;
  }
  @keyframes kick-spin {
    to { transform: rotate(360deg); }
  }

  .badge-spin {
    animation: badge-spin 16s linear infinite;
  }
  @keyframes badge-spin {
    to { transform: rotate(360deg); }
  }

  .float-card {
    animation: float-bob 7s ease-in-out infinite;
  }
  .float-card:last-of-type {
    animation-duration: 9s;
    animation-direction: reverse;
  }
  @keyframes float-bob {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -12px; }
  }

  .stat-card {
    padding: 0.5rem 1rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .stat-card {
      padding: 0.6rem 2rem;
    }
  }

  .scroll-mouse {
    position: relative;
    display: block;
    width: 22px;
    height: 34px;
    border: 1.5px solid currentColor;
    border-radius: 11px;
    opacity: 0.8;
  }
  .scroll-dot {
    position: absolute;
    left: 50%;
    top: 7px;
    width: 3px;
    height: 6px;
    margin-left: -1.5px;
    border-radius: 2px;
    background: currentColor;
    animation: scroll-dot 1.7s var(--ease-out-expo) infinite;
  }
  @keyframes scroll-dot {
    0% { opacity: 0; transform: translateY(0); }
    30% { opacity: 1; }
    70% { opacity: 1; transform: translateY(10px); }
    100% { opacity: 0; transform: translateY(12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      opacity: 1;
      animation: none;
    }
    .tw-caret,
    .kick-star,
    .badge-spin,
    .float-card,
    .scroll-dot {
      animation: none;
    }
  }
</style>
