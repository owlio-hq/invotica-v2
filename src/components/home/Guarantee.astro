---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { guarantees } from "@/data/site";
---

<section class="section-y container-x" id="guarantee">
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <SectionLabel text="Our Promise" class="justify-center [&::before]:hidden" />
    <h2 class="mt-5 text-h2">We remove the risk.</h2>
    <p class="mt-4 text-lead text-ink-soft">
      Working with an agency shouldn't be stressful. Here are the guarantees we
      make to every single client.
    </p>
  </div>

  <div class="mt-14 grid gap-6 md:grid-cols-3">
    {
      guarantees.map((g, i) => (
        <article
          class="flex flex-col items-start rounded-3xl bg-cream-200/60 p-8 ring-1 ring-cream-300"
          data-reveal
          data-reveal-delay={i * 100}
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-forest text-cream">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M12 3l7 3v5c0 4.2-2.8 7.6-7 9-4.2-1.4-7-4.8-7-9V6l7-3z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"
              />
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <h3 class="mt-6 text-h3">{g.title}</h3>
          <p class="mt-3 leading-relaxed text-ink-soft">{g.body}</p>
        </article>
      ))
    }
  </div>
</section>
