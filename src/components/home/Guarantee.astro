---
import Kicker from "@/components/ui/Kicker.astro";
import { guarantees } from "@/data/site";
---

<section class="container-x py-16 sm:py-20" id="guarantee">
  <div class="mx-auto flex max-w-2xl flex-col items-center text-center" data-reveal>
    <Kicker text="Our promise" align="center" />
    <h2 class="mt-6 text-[clamp(2.2rem,1rem+4vw,4rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
      We remove the <span class="marker">risk.</span>
    </h2>
    <p class="mt-5 text-lead text-ink-soft">
      Working with an agency shouldn't be stressful. Here are the guarantees we
      make to every single client.
    </p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-3">
    {
      guarantees.map((g, i) => (
        <article
          data-reveal
          data-reveal-delay={i * 100}
          class="group flex flex-col items-start rounded-3xl bg-paper-200 p-8 ring-1 ring-paper-300 transition-all duration-300 hover:-translate-y-1.5 hover:ring-blue"
        >
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-lime text-lime-deep transition-transform duration-300 group-hover:-rotate-6">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M12 3l7 3v5c0 4.2-2.8 7.6-7 9-4.2-1.4-7-4.8-7-9V6l7-3z"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              />
              <path
                d="M9 12l2 2 4-4"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <h3 class="mt-6 text-h3">{g.title}</h3>
          <p class="mt-3 leading-relaxed text-ink-soft">{g.body}</p>
        </article>
      ))
    }
  </div>
</section>
