---
import SectionLabel from "@/components/ui/SectionLabel.astro";

const chips = ["Mobile-first", "Lightning fast", "Pixel-perfect"];
---

<section class="section-y relative overflow-hidden bg-ink text-paper" id="showcase">
  <!-- soft blue bloom -->
  <div
    class="pointer-events-none absolute -left-32 top-1/3 h-96 w-96 rounded-full bg-blue/25 blur-[120px]"
    aria-hidden="true"
  ></div>

  <div class="container-x relative grid items-center gap-14 lg:grid-cols-2">
    <!-- copy -->
    <div data-reveal>
      <SectionLabel text="Built in the open" class="!text-blue-soft" />
      <h2 class="mt-5 max-w-md text-paper text-h2">
        Watch it come alive — on <span class="italic text-blue-bright">every screen.</span>
      </h2>
      <p class="mt-6 max-w-md leading-relaxed text-paper/60">
        We design mobile-first, then scale up. Every build is responsive by default,
        so it looks sharp whether your customer is on a phone on the bus or a desktop
        at their desk. Scroll and see for yourself.
      </p>

      <ul class="mt-8 flex flex-wrap gap-3">
        {
          chips.map((c) => (
            <li class="rounded-full bg-white/[0.06] px-4 py-2 text-sm font-medium text-paper/80 ring-1 ring-white/10">
              {c}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- phone -->
    <div class="relative flex justify-center lg:justify-end">
      <!-- rotating sticker badge -->
      <div
        class="badge-spin absolute -left-2 top-4 z-20 hidden h-24 w-24 place-items-center rounded-full bg-blue-bright text-ink sm:grid"
        aria-hidden="true"
      >
        <svg viewBox="0 0 100 100" class="absolute inset-0 h-full w-full">
          <defs>
            <path id="badgeArc" d="M50,50 m-34,0 a34,34 0 1,1 68,0 a34,34 0 1,1 -68,0" />
          </defs>
          <text class="fill-ink text-[10.5px] font-semibold uppercase tracking-[0.18em]">
            <textPath href="#badgeArc" startOffset="0">
              Responsive by default ·
            </textPath>
          </text>
        </svg>
        <span class="text-xl font-bold">↗</span>
      </div>

      <!-- device -->
      <div class="phone relative z-10 w-[262px] rounded-[2.6rem] bg-[#05060a] p-2.5 shadow-[0_40px_90px_-30px_rgba(0,0,0,0.9)] ring-1 ring-white/10">
        <!-- notch -->
        <div class="absolute left-1/2 top-3 z-20 h-1.5 w-16 -translate-x-1/2 rounded-full bg-white/15"></div>
        <!-- screen -->
        <div class="phone-screen relative h-[548px] overflow-hidden rounded-[2.1rem] bg-paper">
          <!-- the scrolling mini-site -->
          <div data-phone-track class="will-change-transform">
            <!-- mini nav -->
            <div class="flex items-center justify-between bg-paper px-5 py-4">
              <div class="flex items-center gap-1.5">
                <span class="h-3.5 w-1.5 rounded bg-blue"></span>
                <span class="h-2.5 w-1 rounded bg-ink"></span>
                <span class="h-1.5 w-1.5 rounded-full bg-blue-bright"></span>
              </div>
              <div class="flex gap-1.5">
                <span class="h-1.5 w-5 rounded-full bg-ink/15"></span>
                <span class="h-1.5 w-5 rounded-full bg-ink/15"></span>
                <span class="h-1.5 w-8 rounded-full bg-blue"></span>
              </div>
            </div>

            <!-- mini hero -->
            <div class="mx-3 rounded-2xl bg-blue px-5 pb-6 pt-7 text-white">
              <span class="h-2 w-16 rounded-full bg-white/40"></span>
              <div class="mt-4 space-y-2">
                <span class="block h-3.5 w-11/12 rounded bg-white"></span>
                <span class="block h-3.5 w-9/12 rounded bg-white"></span>
                <span class="block h-3.5 w-7/12 rounded bg-white/80"></span>
              </div>
              <span class="mt-5 inline-block h-7 w-28 rounded-full bg-white"></span>
            </div>

            <!-- stat row -->
            <div class="mx-3 mt-4 grid grid-cols-3 gap-2">
              {
                [0, 1, 2].map(() => (
                  <div class="rounded-xl bg-paper-200 px-2 py-3 text-center">
                    <span class="mx-auto block h-3 w-8 rounded bg-ink/70" />
                    <span class="mx-auto mt-1.5 block h-1.5 w-10 rounded bg-ink/25" />
                  </div>
                ))
              }
            </div>

            <!-- two cards -->
            <div class="mx-3 mt-4 grid grid-cols-2 gap-2">
              <div class="rounded-xl bg-ink p-3">
                <span class="block h-10 w-full rounded-lg bg-blue/70"></span>
                <span class="mt-2 block h-1.5 w-3/4 rounded bg-white/40"></span>
                <span class="mt-1.5 block h-1.5 w-1/2 rounded bg-white/25"></span>
              </div>
              <div class="rounded-xl bg-paper-200 p-3 ring-1 ring-paper-300">
                <span class="block h-10 w-full rounded-lg bg-blue-100"></span>
                <span class="mt-2 block h-1.5 w-3/4 rounded bg-ink/30"></span>
                <span class="mt-1.5 block h-1.5 w-1/2 rounded bg-ink/15"></span>
              </div>
            </div>

            <!-- text section -->
            <div class="mx-3 mt-5">
              <span class="block h-2.5 w-24 rounded bg-blue"></span>
              <div class="mt-3 space-y-2">
                <span class="block h-2 w-full rounded bg-ink/15"></span>
                <span class="block h-2 w-11/12 rounded bg-ink/15"></span>
                <span class="block h-2 w-10/12 rounded bg-ink/15"></span>
                <span class="block h-2 w-9/12 rounded bg-ink/10"></span>
              </div>
            </div>

            <!-- image band -->
            <div class="mx-3 mt-5 h-28 rounded-2xl bg-gradient-to-br from-blue to-blue-deep"></div>

            <!-- mini footer -->
            <div class="mt-5 bg-ink px-5 py-6">
              <div class="flex items-center gap-1.5">
                <span class="h-3 w-1.5 rounded bg-blue"></span>
                <span class="h-2 w-1 rounded bg-white"></span>
              </div>
              <div class="mt-3 grid grid-cols-3 gap-2">
                {
                  [0, 1, 2].map(() => (
                    <div class="space-y-1.5">
                      <span class="block h-1.5 w-10 rounded bg-white/30" />
                      <span class="block h-1.5 w-8 rounded bg-white/15" />
                      <span class="block h-1.5 w-9 rounded bg-white/15" />
                    </div>
                  ))
                }
              </div>
            </div>
            <!-- tail spacer so the scroll ends cleanly -->
            <div class="h-6 bg-ink"></div>
          </div>

          <!-- subtle top/bottom fades inside the screen -->
          <div class="pointer-events-none absolute inset-x-0 top-0 h-6 bg-gradient-to-b from-paper to-transparent"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .badge-spin {
    animation: badge-spin 14s linear infinite;
  }
  @keyframes badge-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .badge-spin {
      animation: none;
    }
  }
</style>
