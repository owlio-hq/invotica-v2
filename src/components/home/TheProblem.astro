---
import { problems } from "@/data/site";
---

<section class="section-y container-x" id="problem">
  <div class="grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-5" data-reveal>
      <span class="sticker -rotate-2">★ The problem</span>
      <h2 class="mt-7 text-[clamp(2.2rem,1rem+4vw,4rem)] font-light leading-[1.02] tracking-tight">
        Every day without a website is a client you
        <span class="marker">didn't know you lost.</span>
      </h2>
      <!-- hand-drawn arrow pointing to the list -->
      <svg
        class="mt-8 hidden h-16 w-24 text-ink/25 lg:block"
        viewBox="0 0 100 70"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M6 10c30 4 52 18 60 44"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-dasharray="1 9"
        ></path>
        <path
          d="M52 52l16 4 2-17"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        ></path>
      </svg>
    </div>

    <div class="lg:col-span-7" data-fx="stagger">
      {
        problems.map((p, i) => (
          <article class="group flex gap-6 border-t border-paper-300 py-8 first:border-t-0 sm:gap-8 sm:py-9 lg:first:border-t lg:first:pt-9">
            <span class="font-display text-5xl font-medium leading-none text-ink/12 tabular-nums sm:text-6xl">
              0{i + 1}
            </span>
            <div>
              <h3 class="text-h3 transition-colors duration-300 group-hover:text-blue">
                {p.title}
              </h3>
              <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">{p.body}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
