---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { problems } from "@/data/site";
---

<section class="section-y container-x" id="problem">
  <div class="grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-5" data-reveal>
      <SectionLabel text="The Problem" />
      <h2 class="mt-5 max-w-md text-h2">
        Every day without a website is a client you didn't know you lost.
      </h2>
    </div>

    <div class="lg:col-span-7">
      <div class="flex flex-col divide-y divide-cream-300 border-t border-cream-300">
        {
          problems.map((p, i) => (
            <article
              class="group flex gap-5 py-7 transition-colors duration-300 sm:gap-8"
              data-reveal
              data-reveal-delay={i * 90}
            >
              <span class="font-display text-xl text-terracotta/70 tabular-nums">
                0{i + 1}
              </span>
              <div>
                <h3 class="text-h3 transition-colors duration-300 group-hover:text-forest">
                  {p.title}
                </h3>
                <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">{p.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
