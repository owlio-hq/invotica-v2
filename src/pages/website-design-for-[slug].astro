---
/**
 * Industry landing pages — one static route per entry in src/data/industries.ts.
 * Targets long-tail "website design for X" searches instead of the generic head
 * term. Each page carries its own FAQPage schema built from that industry's FAQ.
 */
import Base from "@/layouts/Base.astro";
import Kicker from "@/components/ui/Kicker.astro";
import Button from "@/components/ui/Button.astro";
import PlanCard from "@/components/ui/PlanCard.astro";
import SquiggleArrow from "@/components/ui/SquiggleArrow.astro";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import FinalCTA from "@/components/ui/FinalCTA.astro";
import { industries } from "@/data/industries";
import { plans } from "@/data/site";

export function getStaticPaths() {
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const plan = plans.find((p) => p.id === industry.recommendedPlanId)!;
const others = industries.filter((i) => i.slug !== industry.slug);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: industry.faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<Base title={industry.metaTitle} description={industry.metaDescription}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- hero -->
  <section class="container-x pb-6 pt-28 sm:pt-32">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center" data-reveal>
      <Kicker text={industry.kicker} align="center" />
      <h1 class="mt-6 text-[clamp(2.3rem,1rem+4.2vw,4.25rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
        {industry.h1[0]} <span class="marker">{industry.h1[1]}</span>
      </h1>
      <p class="mt-5 text-lead text-ink-soft">{industry.intro}</p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <Button href="/contact" variant="blue">Get a free quote</Button>
        <Button href="/pricing" variant="dark">See pricing</Button>
      </div>
    </div>
  </section>

  <!-- pain points -->
  <section class="section-y container-x">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5" data-reveal>
        <Kicker text="What it's costing you" />
        <h2 class="mt-6 text-[clamp(2rem,1rem+3.4vw,3.5rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
          Where {industry.audience} <span class="marker">lose customers.</span>
        </h2>
        <SquiggleArrow
          variant="bouncy"
          direction="right"
          strokeWidth={5}
          class="mt-8 hidden h-24 w-40 rotate-[18deg] text-blue lg:block"
        />
      </div>

      <div class="lg:col-span-7">
        {
          industry.painPoints.map((p, i) => (
            <article
              data-reveal
              data-reveal-delay={i * 90}
              class="group flex gap-6 border-t border-paper-300 py-8 first:border-t-0 sm:gap-8 sm:py-9 lg:first:border-t lg:first:pt-9"
            >
              <span class="font-display text-5xl font-medium leading-none text-ink/12 tabular-nums sm:text-6xl">
                0{i + 1}
              </span>
              <div>
                <h3 class="text-h3 transition-colors duration-300 group-hover:text-blue">{p.title}</h3>
                <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">{p.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- must-haves -->
  <section class="section-y bg-paper-200 !py-20">
    <div class="container-x">
      <div class="mx-auto mb-10 flex max-w-xl flex-col items-center text-center" data-reveal>
        <Kicker text="What we build in" align="center" />
        <h2 class="mt-6 text-[clamp(1.9rem,1rem+3vw,3rem)] font-semibold tracking-[-0.02em]">
          What a {industry.singular} site actually <span class="marker">needs.</span>
        </h2>
      </div>
      <ul class="mx-auto flex max-w-3xl flex-col divide-y divide-paper-300 border-y border-paper-300">
        {
          industry.mustHaves.map((item, i) => (
            <li class="flex items-start gap-4 py-5" data-reveal data-reveal-delay={i * 60}>
              <svg class="mt-1 h-5 w-5 shrink-0 text-blue" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path
                  d="M4 10.5l3.5 3.5L16 5.5"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span class="leading-relaxed text-ink-soft">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- recommended plan -->
  <section class="section-y container-x">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-6" data-reveal>
        <Kicker text="Where most start" />
        <h2 class="mt-6 text-[clamp(1.9rem,1rem+3vw,3rem)] font-semibold tracking-[-0.02em]">
          For {industry.audience}, we usually recommend <span class="marker">{plan.name}.</span>
        </h2>
        <p class="mt-5 max-w-md leading-relaxed text-ink-soft">{industry.recommendedReason}</p>
        <div class="mt-8">
          <Button href="/pricing" variant="dark">Compare every plan</Button>
        </div>
      </div>
      <div class="lg:col-span-5 lg:col-start-8" data-reveal data-reveal-delay="120">
        <PlanCard plan={plan} mode="teaser" />
      </div>
    </div>
  </section>

  <!-- faq -->
  <section class="section-y container-x">
    <div class="mx-auto mb-10 flex max-w-xl flex-col items-center text-center" data-reveal>
      <Kicker text="FAQ" align="center" />
      <h2 class="mt-6 text-[clamp(1.9rem,1rem+3vw,3rem)] font-semibold tracking-[-0.02em]">
        Questions, <span class="marker">answered.</span>
      </h2>
    </div>
    <div data-reveal>
      <FaqAccordion items={industry.faq} />
    </div>
  </section>

  <!-- cross-links to sibling industries (internal linking for crawlers) -->
  <section class="container-x pb-4">
    <div class="mx-auto max-w-3xl border-t border-paper-300 pt-10 text-center" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blue">Other industries we build for</p>
      <ul class="mt-5 flex flex-wrap justify-center gap-2.5">
        {
          others.map((o) => (
            <li>
              <a
                href={`/website-design-for-${o.slug}`}
                class="inline-block rounded-full bg-paper-200 px-4 py-2 text-sm font-medium text-ink-soft ring-1 ring-paper-300 transition-colors hover:bg-white hover:text-blue hover:ring-blue"
              >
                {o.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <FinalCTA title={industry.ctaTitle} body="Tell us about your business and we'll get you online." />
</Base>
