---
import Base from "@/layouts/Base.astro";
import Kicker from "@/components/ui/Kicker.astro";
import ContactForm from "@/components/contact/ContactForm.astro";
import { site, guarantees } from "@/data/site";
---

<Base
  title="Contact"
  description="Get a free quote from Invotica. Tell us about your business and we'll reply within hours — custom websites for Canadian businesses, built fast."
>
  <section class="container-x pb-16 pt-36 sm:pt-44">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- left: intro + details -->
      <div class="lg:col-span-5">
        <div data-reveal>
          <Kicker text="Contact" />
          <h1 class="mt-6 text-[clamp(2.4rem,1rem+4vw,4.25rem)] font-semibold leading-[1.14] tracking-[-0.02em]">
            Let's get you <span class="marker">online.</span>
          </h1>
          <p class="mt-5 text-lead text-ink-soft">
            Tell us a little about your business. We read every message and reply
            in hours, not days — and your quote is always free.
          </p>
        </div>

        <dl class="mt-10 flex flex-col gap-5" data-reveal data-reveal-delay="120">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-blue">Email</dt>
            <dd class="mt-1">
              <a class="text-lg text-ink underline decoration-blue/30 decoration-1 underline-offset-4 transition-colors hover:text-blue" href={`mailto:${site.email}`}>
                {site.email}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-blue">Phone</dt>
            <dd class="mt-1 text-lg text-ink">{site.phone}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-blue">Where</dt>
            <dd class="mt-1 text-lg text-ink">{site.location}</dd>
          </div>
        </dl>

        <ul class="mt-10 flex flex-col gap-3" data-reveal data-reveal-delay="200">
          {
            guarantees.map((g) => (
              <li class="flex items-center gap-3 text-sm text-ink-soft">
                <svg class="h-5 w-5 shrink-0 text-blue" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {g.title}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- right: form -->
      <div class="lg:col-span-6 lg:col-start-7">
        <div
          class="rounded-[1.75rem] bg-white p-6 shadow-[0_30px_70px_-40px_rgba(10,10,10,0.3)] ring-1 ring-paper-300 sm:p-9"
          data-reveal
          data-reveal-delay="120"
        >
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</Base>
